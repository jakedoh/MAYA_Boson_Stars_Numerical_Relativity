private:
CCTK_REAL puncture_utau_min TYPE=scalar tags='checkpoint="no"'
CCTK_REAL PunctureInfo[3] TYPE=scalar tags='checkpoint="no"'
{
  radii, center_x, center_y, center_z
} "Puncture information for applying the Faber limit"

## Mask is 1 if original Con2Prim failed. If fallback fails, code aborts.
CCTK_INT failed_con2prim_mask  type = GF Timelevels = 1 tags='Prolongation="None"' "Flag where con2prim failed"

