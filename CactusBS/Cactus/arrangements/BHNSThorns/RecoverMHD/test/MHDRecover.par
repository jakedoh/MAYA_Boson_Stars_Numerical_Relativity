!DESC "Test Conservatives -> Primitives -> Conservatives with MHD active"

ActiveThorns = "pugh pughreduce pughslab LocalReduce"

cactus::cctk_itlast 			= 	5

driver::ghost_size			=	2
driver::global_nx 			= 	15
driver::global_ny 			= 	15
driver::global_nz 			= 	15

ActiveThorns = "coordbase symbase cartgrid3d boundary"

grid::type 				= 	"BySpacing"
grid::domain 				= 	"full"
grid::dxyz 				= 	0.5

ActiveThorns = "time"

time::dtfac 				= 	0.25

ActiveThorns = "ioutil ioascii iobasic"

IO::out_fileinfo			=	"none"
IO::out_dir 				= 	$parfile

IOBasic::outInfo_every 			= 	1
IOBasic::outInfo_vars 			= 	"HydroBase::rho"

ActiveThorns = "nanchecker mol"

methodoflines::ode_method 		= 	"rk2"
methodoflines::mol_intermediate_steps	=	2

ActiveThorns = "ADMBase StaticConformal SpaceMask CoordGauge ADMMacros ADMCoupling"

ADMBase::evolution_method		=	"none"
ADMBase::initial_shift			=	"none"
ADMBase::metric_type			= 	"physical"
SpaceMask::use_mask			=	"yes"

ActiveThorns = "eos_base eos_idealfluid eos_polytrope"

EOS_Ideal_Fluid::eos_ideal_fluid_gamma	=	2

ActiveThorns = "hydrobase tmunubase whisky reconstructTVD riemannsolverroe recovermhd sphericalsurface"

TmunuBase::stress_energy_storage = "yes"
TmunuBase::stress_energy_at_RHS  = "yes"
HydroBase::initial_Bvec = "zero"
HydroBase::evolution_method = "Scotch_MHD_Bvec"
HydroBase::timelevels = 3

recovermhd::solver_tolerance = 1e-12

whisky::riemann_solver			=	"Roe"
whisky::whisky_eos_type			=	"General"
whisky::whisky_eos_table		=	"Ideal_Fluid"
whisky::whisky_stencil			=	2
whisky::recon_method			=	"tvd"
reconstructTVD::tvd_limiter		=	"minmod"
whisky::bound				=	"flat"
whisky::whisky_maxnumevolvedvars	=	8
Whisky::Whisky_MaxNumConstrainedVars    =       14

ActiveThorns = "whisky_init_data"

ADMBase::initial_data			=	"con2prim2con_test"
