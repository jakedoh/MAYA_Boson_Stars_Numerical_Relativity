
#############################################################
# Parameter file for running a single puncture with matter
#############################################################

ActiveThorns = "SphericalInfall CoordBase SymBase Boundary InitBase CartGrid3d CarpetIOBasic IOUtil Carpet CarpetLib Vectors CarpetReduce CarpetInterp CarpetSlab  LoopControl GSL ADMBase StaticConformal SphericalSurface AEILocalInterp ReflectionSymmetry HydroBase Outflow CarpetRegrid2 CarpetTracker"

#############################################################
# Grid
#############################################################

CoordBase::domainsize                   = minmax

CoordBase::boundary_size_x_lower        = 3
CoordBase::boundary_size_y_lower        = 3
CoordBase::boundary_size_z_lower        = 3
CoordBase::boundary_shiftout_x_lower    = 1
CoordBase::boundary_shiftout_y_lower    = 1
CoordBase::boundary_shiftout_z_lower    = 1

CoordBase::boundary_size_x_upper        = 3
CoordBase::boundary_size_y_upper        = 3
CoordBase::boundary_size_z_upper        = 3
CoordBase::boundary_shiftout_x_upper    = 0
CoordBase::boundary_shiftout_y_upper    = 0
CoordBase::boundary_shiftout_z_upper    = 0

CartGrid3D::type                        = "coordbase"
CartGrid3D::domain                      = "full"
CartGrid3D::avoid_origin                = "no"

ReflectionSymmetry::reflection_x   = yes
ReflectionSymmetry::reflection_y   = yes
ReflectionSymmetry::reflection_z   = yes
ReflectionSymmetry::avoid_origin_x = no
ReflectionSymmetry::avoid_origin_y = no
ReflectionSymmetry::avoid_origin_z = no

CoordBase::xmin                         = 0
CoordBase::ymin                         = 0
CoordBase::zmin                         = 0
CoordBase::xmax                         = 12
CoordBase::ymax                         = 12
CoordBase::zmax                         = 12
CoordBase::dx                           = 0.5
CoordBase::dy                           = 0.5
CoordBase::dz                           = 0.5

#############################################################
# CarpetRegrid
#############################################################


#############################################################
# Mesh refinement
#############################################################

CarpetRegrid2::num_centres          = 1
CarpetRegrid2::regrid_every               = 128
CarpetRegrid2::freeze_unaligned_levels = "yes" 
CarpetRegrid2::freeze_unaligned_parent_levels = "yes" 
Carpet::grid_coordinates_filename = "grid.asc" 
CarpetRegrid2::min_distance = 0
CarpetRegrid2::min_fraction = 0.4
CarpetRegrid2::verbose                    = 0
CarpetRegrid2::symmetry_rotating180        = "no"

CarpetRegrid2::num_levels_1  =  2
CarpetRegrid2::position_x_1  =  0
CarpetRegrid2::position_y_1  =  0
CarpetRegrid2::position_z_1  =  0
CarpetRegrid2::radius_1[1]  =  8

#############################################################
# Mesh refinement
#############################################################

Carpet::ghost_size                      = 3
Carpet::domain_from_coordbase           = "yes"
Carpet::max_refinement_levels           = 2
Carpet::refinement_factor               = 2
Carpet::prolongation_order_space        = 5
Carpet::prolongation_order_time         = 2
Carpet::poison_new_timelevels           = "no"
Carpet::check_for_poison                = "no"
Carpet::init_fill_timelevels = "yes"
Carpet::verbose = "no"
Carpet::enable_all_storage		= "yes"

#############################################################
# CarpetLib
#############################################################

CarpetLib::print_memstats_every           = 128
CarpetLib::poison_new_memory            = "yes"
CarpetLib::poison_value                 = 114


#############################################################
# Time integration
#############################################################

Cactus::terminate = "iteration"
Cactus::cctk_itlast = 0

#############################################################
# SphericalInfall
#############################################################

ADMBase::initial_data = "spherical_infall"
SphericalInfall::epsilon = 1e-3
SphericalInfall::rmin    = 2
SphericalInfall::eos_gamma = 1.66666666666667
SphericalInfall::initial_dens = 0.001
SphericalInfall::initial_energy = 1e-06

#############################################################
# SphericalSurface
#############################################################

SphericalSurface::nsurfaces  = 3
SphericalSurface::maxntheta  = 24
SphericalSurface::maxnphi    = 12

SphericalSurface::set_elliptic[0] = "yes"
SphericalSurface::radius_x[0]     = 6.
SphericalSurface::radius_y[0]     = 6.
SphericalSurface::radius_z[0]     = 5.
SphericalSurface::set_elliptic[1] = "yes"
SphericalSurface::radius_x[1]     = 7.
SphericalSurface::radius_y[1]     = 7.
SphericalSurface::radius_z[1]     = 6.
SphericalSurface::set_elliptic[2] = "yes"
SphericalSurface::radius_x[2]     = 8.
SphericalSurface::radius_y[2]     = 8.
SphericalSurface::radius_z[2]     = 7.

SphericalSurface::ntheta[0] = 12
SphericalSurface::nphi  [0] = 10
SphericalSurface::ntheta[1] = 12
SphericalSurface::nphi  [1] = 12
SphericalSurface::ntheta[2] = 24
SphericalSurface::nphi  [2] = 12

#############################################################
# Outflows
#############################################################

Outflow::compute_every        = 2
Outflow::num_detectors        = 3
Outflow::surface_index[0]     = 0
Outflow::surface_index[1]     = 1
Outflow::surface_index[2]     = 2
Outflow::extra_variables      = "grid::x grid::y"
Outflow::interpolator_name    = "Lagrange polynomial interpolation"
Outflow::interpolator_pars    = "order=4"
Outflow::output_2d_data       = "yes"
Outflow::out_format           = ".7e"
Outflow::verbose              = 0

#############################################################
# Output
#############################################################

IO::out_dir                   = $parfile
IO::out_fileinfo              = "all"

CarpetIOBasic::outInfo_every        = 2
CarpetIOBasic::outInfo_vars         = "Outflow::outflow_flux[0] Outflow::outflow_flux[1] Outflow::outflow_flux[2]"


