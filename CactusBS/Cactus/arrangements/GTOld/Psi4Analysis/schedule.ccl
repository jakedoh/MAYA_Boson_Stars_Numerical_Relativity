# Schedule definitions for thorn IntegratePsi4
# $Header:$
#

STORAGE: intpsi4_group, surface_arrays, scalars_real, scalars_int, detector_scalars

schedule Psi4Analysis_Init_Integrals at CCTK_INITIAL
{
  LANG: C
  OPTIONS: global
} "initialize psi4 integral gfs"


schedule Psi4Analysis_loop_over_detectors at ANALYSIS
{
  LANG: C
  OPTIONS: global
} "loop over detectors manually instead of using the schedule.ccl"
