ActiveThorns = "Carpet CarpetLib LoopControl GSL CarpetRegrid CartGrid3D CoordBase InitBase SymBase Boundary RegridBoxes SphericalSurface SwitchGrids Time IOUtil CarpetReduce"

### Grid Setup
Driver::ghost_size = 1
Carpet::domain_from_coordbase = yes

CoordBase::domainsize = minmax

CoordBase::xmin = -0.0
CoordBase::ymin = -0.0
CoordBase::zmin = -0.0
CoordBase::xmax =  24.0
CoordBase::ymax =  24.0
CoordBase::zmax =  6.0
CoordBase::dx   =  3
CoordBase::dy   =  3
CoordBase::dz   =  3

CartGrid3D::type         = coordbase
CartGrid3D::avoid_origin = no

### Intiala data
InitBase::initial_data_setup_method="init_all_levels"

### Driver Stuff
Cactus::terminate               	= 	"any"
Cactus::max_runtime             	= 	1440
Cactus::cctk_final_time         	= 	30
Cactus::cctk_itlast             	= 	50

Carpet::max_refinement_levels           =       3
Carpet::poison_new_timelevels		=	"yes"
CarpetLib::poison_new_memory		=	"yes"
CarpetLib::max_allowed_memory_MB        =	1750
CarpetLib::print_memstats_every		=	-1

### Tracker surfaces
SphericalSurface::nsurfaces = 2
SphericalSurface::set_spherical[1] = yes
SphericalSurface::radius[1] = 1.0

### Grid Description
CarpetRegrid::refinement_levels           = 3
CarpetRegrid::verbose                     = "yes"
CarpetRegrid::refined_regions             = "manual-coordinate-list"
CarpetRegrid::smart_outer_boundaries      = "yes"

RegridBoxes::number_of_centres = 2
RegridBoxes::regrid_every      = 16
RegridBoxes::output_carpetregrid_coordinates = no
RegridBoxes::verbose = 0

RegridBoxes::centre_from[0] = "spherical surface"
RegridBoxes::surface_index[0] = 0
RegridBoxes::refinement_levels[0] = 3
RegridBoxes::centre_0_radius[1] = 2
RegridBoxes::centre_0_radius[2] = 1

RegridBoxes::centre_from[1] = "parameter"
RegridBoxes::refinement_levels[1] = 3
RegridBoxes::centre_1_radius[1] = 2
RegridBoxes::centre_1_radius[2] = 1

### SwitchGrids ###
SwitchGrids::verbose = 1
SwitchGrids::number_of_switches = 2
SwitchGrids::debug_fake_motion = yes

SwitchGrids::switch_criterion[0] = "spherical surface"
SwitchGrids::switch_distance[0] = 10
SwitchGrids::centre_index[0] = 0
SwitchGrids::centre_levels[0] = 2
SwitchGrids::surface_index_b[0] = 1
SwitchGrids::surface_index_a[0] = 0

SwitchGrids::switch_criterion[1] = "coordinate"
SwitchGrids::switch_distance[1] = 5
SwitchGrids::centre_index[1] = 0
SwitchGrids::centre_levels[1] = 1
SwitchGrids::surface_index_a[1] = 0

### Output
IO::out_dir = $parfile

#ActiveThorns = "CarpetIOHDF5"
#IOHDF5::out2d_vars = "grid::x"
#IOHDF5::out2d_every = 4
