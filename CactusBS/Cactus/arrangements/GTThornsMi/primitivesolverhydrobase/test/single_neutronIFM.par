
###########################################################
##   Single Neutron Star Simulation:                     ##
##      Mass = 1.40016 M ( M = 1 M_sun )  
##      r_NS ~ 8.12492                                   
##      x_NS = ( 0, 0, 0 )                         
##      v_NS = ( 0, 0, 0 )
##      Simulate for 3000 M (dx_Star = 0 M)
###########################################################

###############################################################################
##
## Grid structure:
##      rl      Extent          dx[M]           Resolution                              Npts
##      ===========================================================================
##      0        155.998  2.59997  (M/0.384619  , rStar/3.125     )        60 ^3
##      1        77.9992  1.29999  (M/0.769238  , rStar/6.25      )        60 ^3
##      2        38.9996  0.649994        (M/1.53848   , rStar/12.5      )        60 ^3
##      3        19.4998  0.324997        (M/3.07695   , rStar/25        )        60 ^3
##      4        9.7499   0.162498        (M/6.15391   , rStar/50        )        60 ^3
##
###############################################################################


ActiveThorns = "Kranc2BSSNChiMatter TwoPuncturesSolver PrimitiveSolver GenericFD CoordBase SymBase Boundary NanChecker CartGrid3d Time MoL CarpetIOBasic CarpetIOScalar IOUtil Carpet CarpetLib Vectors CarpetReduce CarpetInterp CarpetSlab CarpetIOASCII ADMBase  StaticConformal SphericalSurface AEILocalInterp SpaceMask Slab CarpetIOHDF5 CarpetRegrid2 CarpetTracker MinSearch TimerReport RunStats Dissipation InitBase RotatingSymmetry180 ReflectionSymmetry LoopControl GSL Nice HydroBase EOS_Base EOS_IdealFluid EOS_Polytrope TmunuBase ADMCoupling ADMMacros HTTPD Socket Formaline BowenID SystemTopology hwloc SubspaceNorms  WeylScal4 Psi4Analysis Ylm_Decomp  SphereIntegrate"

#############################################################
# Grid
#############################################################

CartGrid3D::type                        = "coordbase"
CartGrid3D::domain                      = "full"
CartGrid3D::avoid_origin                = "no"

CoordBase::domainsize                   = minmax
CoordBase::xmin                         = 0
CoordBase::ymin                         = -155.998464
CoordBase::zmin                         = 0
CoordBase::xmax                         = 155.998464
CoordBase::ymax                         = 155.998464
CoordBase::zmax                         = 155.998464
CoordBase::dx                           = 2.5999743999999997968
CoordBase::dy                           = 2.5999743999999997968
CoordBase::dz                           = 2.5999743999999997968
CoordBase::boundary_size_x_lower        = 3
CoordBase::boundary_size_y_lower        = 3
CoordBase::boundary_size_z_lower        = 3
CoordBase::boundary_shiftout_x_lower    = 1
CoordBase::boundary_shiftout_y_lower    = 0
CoordBase::boundary_shiftout_z_lower    = 1
CoordBase::boundary_size_x_upper        = 3
CoordBase::boundary_size_y_upper        = 3
CoordBase::boundary_size_z_upper        = 3
CoordBase::boundary_shiftout_x_upper    = 0
CoordBase::boundary_shiftout_y_upper    = 0
CoordBase::boundary_shiftout_z_upper    = 0

#############################################################
# Symmetries
#############################################################

ReflectionSymmetry::reflection_x        = "no"
ReflectionSymmetry::reflection_y        = "no"
ReflectionSymmetry::reflection_z        = "yes"
ReflectionSymmetry::avoid_origin_x      = "no"
ReflectionSymmetry::avoid_origin_y      = "no"
ReflectionSymmetry::avoid_origin_z      = "no"

RotatingSymmetry180::poison_boundaries  = "yes"


#############################################################
# Run statistics
#############################################################

RunStats::calc_every         = 4
RunStats::output_mem_every   = 4
TimerReport::out_every       = 4
TimerReport::out_filename    = "TimerReport"

#############################################################
# CarpetRegrid2/CarpetTracker
#############################################################

CarpetRegrid2::num_centres     = 1
CarpetRegrid2::regrid_every          = 240
CarpetRegrid2::freeze_unaligned_levels = "yes"
CarpetRegrid2::freeze_unaligned_parent_levels = "yes"
Carpet::grid_coordinates_filename = "grid.asc"
CarpetRegrid2::min_distance = 0
CarpetRegrid2::min_fraction = 0.4
CarpetRegrid2::verbose               = 0
CarpetRegrid2::symmetry_rotating180   = "yes"

CarpetRegrid2::num_levels_1  =  5
CarpetTracker::surface[0] = 0
CarpetRegrid2::position_x_1  =  0
CarpetRegrid2::position_y_1  =  0
CarpetRegrid2::position_z_1  =  0
CarpetRegrid2::radius_1[0] = 155.998464
CarpetRegrid2::radius_1[1] = 77.999232
CarpetRegrid2::radius_1[2] = 38.999616
CarpetRegrid2::radius_1[3] = 19.499808
CarpetRegrid2::radius_1[4] = 9.749904



#############################################################
# SphericalSurface
#############################################################

SphericalSurface::nsurfaces  = 4
SphericalSurface::maxntheta  = 120
SphericalSurface::maxnphi    = 90

#############################################################
# MinSearch
#############################################################

MinSearch::x0[0]              = 0
MinSearch::y0[0]              = 0.0
MinSearch::z0[0]              = 0.0
MinSearch::surface_index[0]   = 0
MinSearch::extra_variables[0] = "HydroBase::eps"
#MinSearch::weight_variable[0] = "CarpetReduce::weight"

MinSearch::nminima            = 1
MinSearch::var                = "HydroBase::rho"
MinSearch::verbose            = 0
MinSearch::track_maximum      = "yes"
MinSearch::find_global_minimum = "yes"
MinSearch::interpolator_name  = "Lagrange polynomial interpolation"
MinSearch::interpolator_pars  = "order=4"
MinSearch::find_every         = 1
MinSearch::outfile_basename   = "MinSearch%d.asc"

#############################################################
# Carpet
#############################################################

Carpet::ghost_size                      = 3
Carpet::domain_from_coordbase           = "yes"
Carpet::max_refinement_levels           = 5
Carpet::refinement_factor               = 2
Carpet::prolongation_order_space        = 5
Carpet::prolongation_order_time         = 2
Carpet::use_buffer_zones                = "yes"
Carpet::verbose                         = "no"
Carpet::time_refinement_factors         = "[1,1,1,2,4]"
Carpet::output_timers_every             = 4
Carpet::poison_new_timelevels           = "yes"
Carpet::check_for_poison                = "no"
Carpet::poison_value                    = 113
Carpet::print_timestats_every           = 0
Carpet::init_fill_timelevels            = "yes"

#############################################################
# CarpetLib
#############################################################

CarpetLib::poison_new_memory            = "yes"
CarpetLib::poison_value                 = 114
#CarpetLib::max_allowed_memory_MB        = 1750
CarpetLib::print_memstats_every         = 4

#############################################################
# CarpetInterp
#############################################################

CarpetInterp::tree_search               = "yes"
CarpetInterp::check_tree_search         = "no"

#############################################################
# Time integration
#############################################################

Cactus::terminate                     = "any"
Cactus::max_runtime                   = 2850
Cactus::cctk_final_time               = 0
Cactus::cctk_itlast                   = 100000
Cactus::cctk_timer_output             = "full"
Cactus::highlight_warning_messages    = "no"

Time::dtfac                           = 0.125

MethodOfLines::ode_method             = "RK4"
MethodOfLines::MoL_NaN_Check          = "no"
MethodOfLines::MoL_Intermediate_Steps = 4
MethodOfLines::MoL_Num_Scratch_Levels = 1

#############################################################
# Initial data
#############################################################

ADMBase::initial_data = "twopuncturessolver"
ADMBase::initial_lapse = "utb"
ADMBase::initial_shift = "zero"
ADMBase::evolution_method = "none"

# Uncomment these for fast but very inaccurate initial data
#       TwoPuncturesSolver::npoints_A = 6
#       TwoPuncturesSolver::npoints_B = 6
#       TwoPuncturesSolver::npoints_phi = 6

TwoPuncturesSolver::par_b          =  16.24984
TwoPuncturesSolver::move_origin_x  =  0

# TwoPunctures::grid_setup_method = "evaluation"
TwoPuncturesSolver::psi0_limit = 10

TwoPuncturesSolver::keep_u_around = "yes"
TwoPuncturesSolver::conformal_density_power = 8
TwoPuncturesSolver::Newton_tol = 1e-6
#TwoPuncturesSolver::bypass_solve = "yes"

#############################################################
# Initial data for Matter
#############################################################

BowenID::tov_rho_central[0] = 0.128
BowenID::object_rx[0]  = 0
BowenID::tov_Gamma[0] = 2
BowenID::tov_K[0] = 100
BowenID::object_Px[0] = 0
BowenID::object_Jz[0] = 0
BowenID::verbose = 1
BowenID::compact_object[0] = "tov"
BowenID::tov_rho_atmosphere[0] = 1.28e-11
BowenID::rhohat_exponent = 8
BowenID::testsuite = "yes"
BowenID::sigma_exponent = 8.
BowenID::zero_epsilon = 1e-3

PrimitiveSolver::chiEps       = 0.0001
PrimitiveSolver::testsuite = "yes"
PrimitiveSolver::conformal_density_power = 8
PrimitiveSolver::verbose = 0

#############################################################
# Matter Evolution
#############################################################

HydroBase::timelevels = 3
HydroBase::prolongation_type = "ENO"
HydroBase::initial_hydro = "PrimitiveSolver"
ADMMacros::spatial_order          = 4

TmunuBase::timelevels                = 3
TmunuBase::stress_energy_storage    = "yes"
TmunuBase::stress_energy_at_RHS     = "yes"
#TmunuBase::disable_calcTmunu_inc    = "yes"


HydroBase::evolution_method     = "none"

