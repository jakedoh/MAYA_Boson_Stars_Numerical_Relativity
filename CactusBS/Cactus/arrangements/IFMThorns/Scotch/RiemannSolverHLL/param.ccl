# Parameter definitions for thorn RiemannSolverHLL

CCTK_REAL speed_limit "speed_limit enforces the maximum speed at the faces"
{
  0:*     :: "Just less than 1 makes sense, though less than 1 hinders divergence cleaning."
} 1.

SHARES: Whisky

USES CCTK_INT whisky_stencil
USES BOOLEAN clean_divergence

EXTENDS keyword riemann_solver
{
  "HLL"	:: "HLL"
}
