if (CCTK_EQUALS(update_admbase_variables, "always"))
{
  schedule bssnchi_evolved_to_adm at CCTK_EVOL as bssn_evolved_to_adm after MoL_Evolution
  {
    LANG: C
    READS: Kranc2BSSNChi::A11(Everywhere)
    READS: Kranc2BSSNChi::A21(Everywhere)
    READS: Kranc2BSSNChi::A31(Everywhere)
    READS: Kranc2BSSNChi::A22(Everywhere)
    READS: Kranc2BSSNChi::A32(Everywhere)
    READS: Kranc2BSSNChi::A33(Everywhere)
    READS: Kranc2BSSNChi::alpha(Everywhere)
    READS: Kranc2BSSNChi::beta1(Everywhere)
    READS: Kranc2BSSNChi::beta2(Everywhere)
    READS: Kranc2BSSNChi::beta3(Everywhere)
    READS: Kranc2BSSNChi::chi(Everywhere)
    READS: Kranc2BSSNChi::h11(Everywhere)
    READS: Kranc2BSSNChi::h21(Everywhere)
    READS: Kranc2BSSNChi::h31(Everywhere)
    READS: Kranc2BSSNChi::h22(Everywhere)
    READS: Kranc2BSSNChi::h32(Everywhere)
    READS: Kranc2BSSNChi::h33(Everywhere)
    READS: Kranc2BSSNChi::K(Everywhere)
    WRITES: admbase::alp(Everywhere)
    WRITES: admbase::betax(Everywhere)
    WRITES: admbase::betay(Everywhere)
    WRITES: admbase::betaz(Everywhere)
    WRITES: admbase::gxx(Everywhere)
    WRITES: admbase::gxy(Everywhere)
    WRITES: admbase::gxz(Everywhere)
    WRITES: admbase::gyy(Everywhere)
    WRITES: admbase::gyz(Everywhere)
    WRITES: admbase::gzz(Everywhere)
    WRITES: admbase::kxx(Everywhere)
    WRITES: admbase::kxy(Everywhere)
    WRITES: admbase::kxz(Everywhere)
    WRITES: admbase::kyy(Everywhere)
    WRITES: admbase::kyz(Everywhere)
    WRITES: admbase::kzz(Everywhere)
  } "bssnchi_evolved_to_adm"
}

schedule Kranc2BSSNChi_SelectBoundConds in MoL_PostStep
{
  LANG: C
  OPTIONS: level
  SYNC: h_group
  SYNC: A_group
  SYNC: chi_group
  SYNC: K_group
  SYNC: Gam_group
  SYNC: alpha_group
  SYNC: beta_group
  SYNC: betat_group
} "select boundary conditions"

schedule Kranc2BSSNChi_CheckBoundaries at BASEGRID
{
  LANG: C
  OPTIONS: meta
} "check boundaries treatment"

schedule Kranc2BSSNChi_RegisterVars in MoL_Register
{
  LANG: C
  OPTIONS: meta
} "Register Variables for MoL"
schedule group ApplyBCs as Kranc2BSSNChi_ApplyBCs in MoL_PostStep after Kranc2BSSNChi_SelectBoundConds
{
} "Apply boundary conditions controlled by thorn Boundary"
