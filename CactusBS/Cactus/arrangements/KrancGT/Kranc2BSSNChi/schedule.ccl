    WRITES: Kranc2BSSNChi::beta1rhs(Interior)
    WRITES: Kranc2BSSNChi::beta2rhs(Interior)
    WRITES: Kranc2BSSNChi::beta3rhs(Interior)
    WRITES: Kranc2BSSNChi::betat1rhs(Interior)
    WRITES: Kranc2BSSNChi::betat2rhs(Interior)
    WRITES: Kranc2BSSNChi::betat3rhs(Interior)
  } "bssnchi_mueller_shift_6thcentred"
}

