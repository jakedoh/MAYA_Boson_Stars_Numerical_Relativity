!DESC "distorted BH with cartoon and pugh"


ActiveThorns = "sphericalsurface symbase cartoon2d CoordBase waveextract idaxibrillbh spacemask admcoupling admbase staticconformal admmacros coordgauge admanalysis mol bssn_mol admconstraints pughinterp aeilocalinterp localinterp boundary time pugh pughreduce pughslab cartgrid3d ioascii ioutil iobasic nanchecker "


#--- generic output directory
IO::out_dir      = "dbh-cartoon"
IO::out_fileinfo = "none"



#======================================
# Cartoon parameters
#======================================
cartoon2d::cartoon_active       = "yes"
cartoon2d::stencil              = "yes"
cartoon2d::order                = 2
cartoon2d::verbose              = "yes"
adm_bssn::cartoon               = "yes"
waveextract::cartoon           = "yes"
waveextract::nphi              = 1
waveextract::ntheta            = 20
admconstraints::cartoon         = "yes"


#==============================================================================
# Grid setup
#==============================================================================
grid::type                    = "byrange"
grid::avoid_origin            = "no"
grid::domain                  = "bitant"
grid::bitant_plane            = "xy"

driver::global_nx             = 30
driver::global_ny             = 5
driver::global_nz             = 30

driver::ghost_size            = 2

# zero cannot be on axis
# Cartgrid3d can't get x direction right
grid::xmin                    =  -0.88
grid::xmax                    =  12.01
grid::ymin                    =  -0.89
grid::ymax                    =  0.89
grid::zmin                    =  -0.89
grid::zmax                    =  12.00

cactus::cctk_itlast           = 10
time::dtfac                   = 0.375

#--- axisymmetric brill wave+bh
admbase::initial_data              = "axibrillbh"
idaxibrillbh::amp                  = 0.1
idaxibrillbh::eta0                 = 0.0
idaxibrillbh::sigma                = 1.0
idaxibrillbh::etamax               = 6.0
idaxibrillbh::n                    = 4
idaxibrillbh::ne                   = 302
idaxibrillbh::nq                   = 54
admbase::initial_shift             = "zero"
admbase::evolution_method          = "adm_bssn"
admbase::metric_type               = "static conformal"
staticconformal::conformal_storage = "factor+derivs+2nd derivs"

#--- numerics
mol::ode_method        = "icn"
adm_bssn::ICN_itnum    = 3
adm_bssn::bound        = "newrad"
adm_bssn::stencil_size = 2
adm_bssn::advection    = "upwind2"
boundary::radpower     = 3

#--- gauge
admbase::initial_lapse          = "one"
admbase::lapse_evolution_method = "1+log"
adm_bssn::lapsesource           = "modified"
adm_bssn::harmonic_f            = 2.0
adm_bssn::LapsePsiPower         = 4
adm_bssn::AlphaDissip           = 2.0
adm_bssn::force_lapse_positive  = "yes"
admbase::shift_evolution_method = "gamma0"
adm_bssn::ShiftGammaCoeff       = 0.75
adm_bssn::BetaDriver            = 1.1
adm_bssn::ShiftAlpPower         = 1
adm_bssn::ShiftPsiPower         = 2

#--- waveextract
waveextract::out_every                 = 1
waveextract::interpolation_operator    = "Lagrange polynomial interpolation"
waveextract::interpolation_order       = 2
waveextract::maximum_detector_number   = 5
waveextract::rsch2_computation         = "average Schwarzschild metric"
waveextract::verbose                   = 9
waveextract::l_mode                    = 5
waveextract::m_mode                    = 5
waveextract::detector_radius[0]        = 4.0
waveextract::detector_radius[1]        = 4.1
waveextract::detector_radius[2]        = 4.2
waveextract::detector_radius[3]        = 4.3
waveextract::detector_radius[4]        = 4.4

#--- output
iobasic::outScalar_every                = 1
iobasic::outScalar_vars                 = "admbase::alp admbase::metric admbase::shift admconstraints::momentum admconstraints::ham admconstraints::normalized_hamiltonian"
iobasic::outInfo_every                  = 1
iobasic::outInfo_vars                   = "admbase::alp admconstraints::ham"
ioascii::out1D_every                    = 1
ioascii::out1D_vars                     = "admbase::alp admbase::metric admbase::shift admconstraints::momentum admconstraints::ham admconstraints::normalized_hamiltonian"

#--- nanchecker
nanchecker::check_every     = 1
nanchecker::check_vars      = "admbase::metric admbase::curv"
nanchecker::action_if_found = "terminate"

#--- timing
pugh::timer_output        = "yes"
cactus::cctk_timer_output = "FULL"

sphericalsurface::nsurfaces = 1
