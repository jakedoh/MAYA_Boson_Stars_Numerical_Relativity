!DESC "Schwarzschild test case. This should give 0 in the wave forms."
#
# $Id: schwarzschild.par 24 2006-12-20 15:58:23Z tradke $
#

ActiveThorns = "sphericalsurface nanchecker symbase spacemask CoordBase Boundary CartGrid3D Time IOUtil IOASCII PUGH PUGHSlab PUGHInterp PUGHReduce WaveExtract ADMBase StaticConformal IDAnalyticBH ADM ADMMacros CoordGauge aeilocalinterp"

#--- grid
driver::global_nx   = 30
driver::global_ny   = 30
driver::global_nz   = 30
grid::type          = "bySpacing"
grid::domain        = "octant"
grid::dxyz          = 0.3
time::dtfac         = 0.2
cactus::cctk_itlast = 5

#--- initial data and evolution
admbase::evolution_method       = "adm"
admbase::initial_data           = "schwarzschild" 
admbase::metric_type            = "static conformal"
admbase::lapse_evolution_method = "geodesic"
idanalyticbh::mass              = 1 

#--- output
IO::out_every        = 1
IO::out_dir          = "schwarzschild"
io::out_fileinfo     = "none"
ioascii::out1d_vars  = "admbase::alp"

#--- waveextract
waveextract::out_every                        = 1
waveextract::interpolation_operator           = "Lagrange polynomial interpolation"
waveextract::interpolation_order              = 2
waveextract::maximum_detector_number          = 2
waveextract::rsch2_computation                = "average Schwarzschild metric"
waveextract::verbose                          = 8
waveextract::l_mode                           = 4
waveextract::m_mode                           = 4
waveextract::detector_radius[0]               = 2.5
waveextract::detector_radius[1]               = 3.0
waveextract::make_interpolator_warnings_fatal = yes

sphericalsurface::nsurfaces = 1
