5328e58bfc8d"],

Cell["\<\
      xxa = x-centre_xa[i];
      yya = y-centre_ya[i];
      zza = z-centre_za[i];

      ra2 = xxa*xxa+yya*yya+zza*zza;
      rra = sqrt(ra2) - r0a[i];\
\>", "Text",
 CellChangeTimes->{3.802043423379306*^9, 
  3.802046911207931*^9},ExpressionUUID->"c9ae0f5b-9f2c-42a5-9ddc-\
663c97b55018"],

