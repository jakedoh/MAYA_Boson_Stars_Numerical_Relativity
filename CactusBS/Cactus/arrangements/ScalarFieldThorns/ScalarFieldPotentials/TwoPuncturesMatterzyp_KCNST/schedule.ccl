# Schedule definitions for thorn TwoPunctures
# $Header: /numrelcvs/HerrmannCVS/TwoPunctures/schedule.ccl,v 1.3 2004/10/25 13:41:10 herrmann Exp $

STORAGE: precomputed_group, mass_group

if (keep_u_around) {
  STORAGE: puncture_u
}

if (keep_psi_static) {
  STORAGE: psi_static
}


SCHEDULE TwoPuncturesMatter IN ADMBase_InitialData
{
  LANG: C
  STORAGE: puncture_u
} "Create puncture black hole initial data"


