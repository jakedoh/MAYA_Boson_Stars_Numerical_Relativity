#########################################################################
# Parameter file for running a single puncture spacetime 
#      Mass M_BH = 1 M_h
#      Spin S^i = (0,0,0.20490704253101)
#########################################################################

###############################################################################
##
## Grid structure: 
##	rl	Extent		dx[M]		Resolution		Npts
##	===========================================================================
##	0 	480     	8       	(M/0.125     )	60 ^3
##	1 	240     	4       	(M/0.25      )	60 ^3
##	2 	120     	2       	(M/0.5       )	60 ^3
##	3 	60      	1       	(M/1         )	60 ^3
##	4 	30      	0.5     	(M/2         )	60 ^3
##	5 	15      	0.25    	(M/4         )	60 ^3
##	6 	7.5     	0.125   	(M/8         )	60 ^3
##	7 	3.75    	0.0625  	(M/16        )	60 ^3
##	8 	1.875   	0.03125 	(M/32        )	60 ^3
##
###############################################################################


ActiveThorns = "IHSpin Kranc2BSSNChiMatter_flrw TwoPuncturesSolver_BS BowenID_BS GenericFD CoordBase SymBase Boundary InitBase NanChecker CartGrid3d Time MoL CarpetIOBasic CarpetIOScalar IOUtil Carpet CarpetLib Vectors CarpetReduce CarpetInterp CarpetSlab  CarpetIOASCII LoopControl GSL CarpetRegrid2 CarpetTracker ADMBase StaticConformal Dissipation SphericalSurface AEILocalInterp SpaceMask ReflectionSymmetry RotatingSymmetry180 Slab CarpetIOHDF5 SphereIntegrate  AHFinderDirect SphereRad ShiftTracker WeylScal4 Multipole ADM_EJP"
ActiveThorns = "EvolveScalarFields_flrw AHMask ExternalEtaBeta tmunubase ADMCoupling scalarAnalysis"
ActiveThorns = "MinSearch MPI Timers HDF5 CycleClock hwloc zlib ADMMacros PeriodicCarpet Psi4Analysis"

#############################################################
# Grid
#############################################################
PeriodicCarpet::periodic = "no"

CoordBase::domainsize                   = minmax

CoordBase::boundary_size_x_lower        = 4
CoordBase::boundary_size_y_lower        = 4
CoordBase::boundary_size_z_lower        = 4
CoordBase::boundary_shiftout_x_lower    = 1
CoordBase::boundary_shiftout_y_lower    = 0
CoordBase::boundary_shiftout_z_lower    = 0

CoordBase::boundary_size_x_upper        = 4
CoordBase::boundary_size_y_upper        = 4
CoordBase::boundary_size_z_upper        = 4
CoordBase::boundary_shiftout_x_upper    = 0
CoordBase::boundary_shiftout_y_upper    = 0
CoordBase::boundary_shiftout_z_upper    = 0

CoordBase::xmin                         = 0
CoordBase::ymin                         = -480
CoordBase::zmin                         = -480
CoordBase::xmax                         = 480
CoordBase::ymax                         = 480
CoordBase::zmax                         = 480
CoordBase::dx                           = 8.0000000000000000000
CoordBase::dy                           = 8.0000000000000000000
CoordBase::dz                           = 8.0000000000000000000

CartGrid3D::type                        = "coordbase"
CartGrid3D::domain                      = "full"
CartGrid3D::avoid_origin                = "no"

ReflectionSymmetry::reflection_x   = no
ReflectionSymmetry::reflection_y   = no
ReflectionSymmetry::reflection_z   = no
ReflectionSymmetry::avoid_origin_x = no
ReflectionSymmetry::avoid_origin_y = no
ReflectionSymmetry::avoid_origin_z = no
 RotatingSymmetry180::poison_boundaries  = "yes"

#TimerReport::out_every = 128
#RunStats::calc_every = 128


#############################################################
# MinSearch
#############################################################

MinSearch::x0[0]               = 0.0
MinSearch::y0[0]               = 0.0
MinSearch::z0[0]               = -40
MinSearch::surface_index[0]    = 1
#MinSearch::extra_variables[0] = "HydroBase::eps"
#MinSearch::weight_variable[0] = "AHMask::AHmasked_weight"

MinSearch::nminima             = 1
MinSearch::dist_cutoff         = 1.47668
MinSearch::var                 = "kranc2bssnchimatter::chi"
MinSearch::verbose             = 0
MinSearch::track_maximum       = "no"
MinSearch::find_global_minimum = "no"
MinSearch::find_localized_minimum = "yes"
MinSearch::interpolator_name   = "Lagrange polynomial interpolation"
MinSearch::interpolator_pars   = "order=4"
MinSearch::find_every          = 16
MinSearch::outfile_basename    = "MinSearch%d.asc"

#############################################################
# Mesh refinement
#############################################################

CarpetRegrid2::num_centres          = 2
CarpetRegrid2::regrid_every               = 16
CarpetRegrid2::freeze_unaligned_levels = "no" 
CarpetRegrid2::freeze_unaligned_parent_levels = "no" 
Carpet::grid_coordinates_filename = "grid.asc" 
CarpetRegrid2::min_distance = 0
CarpetRegrid2::min_fraction = 0.4
CarpetRegrid2::verbose                    = "yes"
CarpetRegrid2::symmetry_rotating180        = "yes"

CarpetTracker::surface     [0] = 0
