BowenID_BS::object_Px[1] = 0
BowenID_BS::object_Py[1] = 0
BowenID_BS::object_Pz[1] = 0.1753170168

BowenID_BS::tov_numpoints = 90001

TwoPuncturesSolver_BS::par_b          =  40
