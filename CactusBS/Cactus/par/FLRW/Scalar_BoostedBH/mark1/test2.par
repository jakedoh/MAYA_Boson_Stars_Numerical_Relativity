#########################################################################
# Parameter file for running a single puncture spacetime 
#      Mass M_BH = 0.5 M_h
#      Spin S^i = (0,0,0)
#########################################################################

###############################################################################
##
## Grid structure: 
##	rl	Extent		dx[M]		Resolution		Npts
##	===========================================================================
##	0 	192     	3.2     	(M/0.3125    )	60 ^3
##	1 	96      	1.6     	(M/0.625     )	60 ^3
##	2 	48      	0.8     	(M/1.25      )	60 ^3
##	3 	24      	0.4     	(M/2.5       )	60 ^3
##	4 	12      	0.2     	(M/5         )	60 ^3
##	5 	6       	0.1     	(M/10        )	60 ^3
##	6 	3       	0.05    	(M/20        )	60 ^3
##	7 	1.5     	0.025   	(M/40        )	60 ^3
##
###############################################################################


ActiveThorns = "ShiftTracker PunctureTracker Kranc2BSSNChi TwoPunctures GenericFD CoordBase SymBase Boundary InitBase NanChecker CartGrid3d Time MoL CarpetIOBasic CarpetIOScalar IOUtil Carpet CarpetLib Vectors CarpetReduce CarpetInterp CarpetSlab  CarpetIOASCII LoopControl GSL CarpetRegrid2 CarpetTracker ADMBase StaticConformal Dissipation SphericalSurface AEILocalInterp SpaceMask ReflectionSymmetry  Slab CarpetIOHDF5 SphereIntegrate Formaline AHFinderDirect IHSpin SphereRad WeylScal4 Multipole ADM_EJP"
#ActiveThorns = "EvolveScalarFields_flrw IDScalarFieldzyp_flrw AHMask ExternalEtaBeta tmunubase ADMCoupling"
ActiveThorns = "MPI Timers HDF5 CycleClock hwloc zlib ADMMacros ExternalEtaBeta PeriodicCarpet"

#############################################################
# Grid
#############################################################
PeriodicCarpet::periodic = "no"

CoordBase::domainsize                   = minmax

CoordBase::boundary_size_x_lower        = 4
CoordBase::boundary_size_y_lower        = 4
CoordBase::boundary_size_z_lower        = 4
CoordBase::boundary_shiftout_x_lower    = 0
CoordBase::boundary_shiftout_y_lower    = 1
CoordBase::boundary_shiftout_z_lower    = 1

CoordBase::boundary_size_x_upper        = 4
CoordBase::boundary_size_y_upper        = 4
CoordBase::boundary_size_z_upper        = 4
CoordBase::boundary_shiftout_x_upper    = 0
CoordBase::boundary_shiftout_y_upper    = 0
CoordBase::boundary_shiftout_z_upper    = 0

CoordBase::xmin                         = -192
CoordBase::ymin                         = 0
CoordBase::zmin                         = 0
CoordBase::xmax                         = 192
CoordBase::ymax                         = 192
CoordBase::zmax                         = 192
CoordBase::dx                           = 3.2000000000000001776
CoordBase::dy                           = 3.2000000000000001776
CoordBase::dz                           = 3.2000000000000001776

CartGrid3D::type                        = "coordbase"
CartGrid3D::domain                      = "full"
CartGrid3D::avoid_origin                = "no"

ReflectionSymmetry::reflection_x   = no
ReflectionSymmetry::reflection_y   = yes
ReflectionSymmetry::reflection_z   = yes
ReflectionSymmetry::avoid_origin_x = no
ReflectionSymmetry::avoid_origin_y = no
ReflectionSymmetry::avoid_origin_z = no
# RotatingSymmetry180::poison_boundaries  = "yes"

#TimerReport::out_every = 128
#RunStats::calc_every = 128

#############################################################
# Mesh refinement
#############################################################

CarpetRegrid2::num_centres          = 1
CarpetRegrid2::regrid_every               = 16

CarpetInterp::tree_search = "yes"
CarpetInterp::check_tree_search = "yes"

CarpetRegrid2::freeze_unaligned_levels = "no" 
CarpetRegrid2::freeze_unaligned_parent_levels = "no" 
Carpet::grid_coordinates_filename = "grid.asc" 
CarpetRegrid2::min_distance = 0
CarpetRegrid2::min_fraction = 0.4
CarpetRegrid2::verbose                    = "yes"
CarpetRegrid2::symmetry_rotating180        = "no"

CarpetTracker:: surface [0]  = 0
PunctureTracker::track                      [0] = yes
PunctureTracker::initial_x                  [0] = -0.000022
PunctureTracker::which_surface_to_store_info[0] = 0
CarpetRegrid2::num_levels_1  =  8
CarpetRegrid2::position_x_1  =  -0.000022
CarpetRegrid2::position_y_1  =  0
CarpetRegrid2::position_z_1  =  0
#PunctureTracker::verbose     = "yes"
# 320, 160, 95, 70, 50, 6.875 (dx_max = 10)
# For 1 processor, (6.875, 0.3125 for CoordBase) 
CarpetRegrid2::radius_1[0] = 192
CarpetRegrid2::radius_1[1] = 96
CarpetRegrid2::radius_1[2] = 48
CarpetRegrid2::radius_1[3] = 24
CarpetRegrid2::radius_1[4] = 12
CarpetRegrid2::radius_1[5] = 6
CarpetRegrid2::radius_1[6] = 3
CarpetRegrid2::radius_1[7] = 1.5


#############################################################
# Carpet
#############################################################

Carpet::ghost_size                      = 4
Carpet::domain_from_coordbase           = "yes"
Carpet::max_refinement_levels           = 8
Carpet::refinement_factor               = 2
Carpet::prolongation_order_space        = 5
Carpet::prolongation_order_time         = 2
Carpet::use_buffer_zones                = "yes"
Carpet::verbose                         = "no"
Carpet::time_refinement_factors         = "[1,1,1,1,2,4,8,16]"
Carpet::output_timers_every             = 16
Carpet::poison_new_timelevels           = "yes"
Carpet::check_for_poison                = "no"
Carpet::poison_value                    = 113
Carpet::print_timestats_every           = 0
Carpet::init_fill_timelevels            = "yes"
Carpet::use_tapered_grids               = "no"

#############################################################
# CarpetLib
#############################################################

CarpetLib::print_memstats_every         = 0
CarpetLib::poison_new_memory            = "yes"
CarpetLib::poison_value                 = 114

#############################################################
# Time integration
#############################################################

Cactus::terminate = "any"
Cactus::max_runtime = 2850
Cactus::cctk_final_time = 1000
Cactus::cctk_itlast = 1000000

# Use 0.5 for RK4 and 0.25 for ICN
Time::dtfac                           = 0.0625
MethodOfLines::ode_method             = "RK4"
MethodOfLines::MoL_NaN_Check          = "no"
MethodOfLines::MoL_Intermediate_Steps = 4
MethodOfLines::MoL_Num_Scratch_Levels = 1

#############################################################
# Initial data
#############################################################

ADMBase::initial_data = "twopunctures"
ADMBase::initial_lapse = "psi^n"
TwoPunctures::initial_lapse_psi_exponent = -2
ADMBase::initial_shift = "zero"
ADMBase::metric_timelevels = 3
ADMBase::lapse_timelevels = 3
ADMBase::shift_timelevels = 3


ADMBase::evolution_method = "Kranc2BSSNChi"
ADMBase::lapse_evolution_method = "Kranc2BSSNChi"
ADMBase::shift_evolution_method = "Kranc2BSSNChi"
ADMBase::dtlapse_evolution_method = "Kranc2BSSNChi"
ADMBase::dtshift_evolution_method = "Kranc2BSSNChi"

TwoPunctures::give_bare_mass = no
TwoPunctures::par_b          =  2.00
TwoPunctures::par_m_plus     =  0.428971795
TwoPunctures::par_m_minus    =  0
TwoPunctures::target_M_plus = 0.5
TwoPunctures::target_M_minus = 0
