TwoPunctures::par_P_plus[1]  =  0
TwoPunctures::par_P_plus[2]  =  0
TwoPunctures::center_offset[0]  = -2.00
TwoPunctures::Newton_maxit = 20
TwoPunctures::TP_epsilon = 1e-3
TwoPunctures::TP_Tiny = 1e-12
TwoPunctures::adm_tol = 1e-6
TwoPunctures::verbose = "yes"

TwoPunctures::npoints_A = 30
TwoPunctures::npoints_B = 30

