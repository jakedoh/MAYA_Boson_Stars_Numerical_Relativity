#EvolveScalarFields::controlmasspositiveornegative = 1


#IDScalarFieldzyp::phi0a[0] = $phi0a   # 2.5
#IDScalarFieldzyp::pi0a[0] =  $pi0a   #0.0

#twopuncturesmatterzyp::m0     = $m0 #1e-2
#twopuncturesmatterzyp::phi00     = $phi00 #1e-2
#twopuncturesmatterzyp::V0     = $V0 #1e-2

#twopuncturesmatterzyp::lamda0     = $lamda0 #0.0
#twopuncturesmatterzyp::Ksign     = 1.0  # 1: negative, 2: positive

#IDScalarFieldzyp::lambdaphia = $lamda0 # this is not entering in the initial data set to zero just in case
##match the initial lambda
#EvolveScalarFields::lambdaphia = $lamda0
#EvolveScalarFields::phiamass = $m0
#EvolveScalarFields::phi00 = $phi00
#EvolveScalarFields::Vi0 = $V0


#############################################################
# a second Scalar field:
#############################################################

#IDScalarFieldzyp::potential = "no"

#IDScalarFieldzyp::gcouple = 0
#IDScalarFieldzyp::STcouplea = 0
#IDScalarFieldzyp::STcoupleb = 0
#IDScalarFieldzyp::lambdaphib = 0
#IDScalarFieldzyp::lambdaphian =0
#IDScalarFieldzyp::lambdaphibn =0
#EvolveScalarFields::gcouple = 0
#EvolveScalarFields::lambdaphib = 0
#EvolveScalarFields::lambdaphian =0
#EvolveScalarFields::lambdaphibn =0
#IDScalarFieldzyp::phiav = 0.0
#IDScalarFieldzyp::phibv = 0
#EvolveScalarFields::phiav = 0.00
#EvolveScalarFields::phibv = 0
#TwopuncturesMatterzyp::STcouplea     = 0
#TwopuncturesMatterzyp::STcoupleb     = 0
#EvolveScalarFields::phibmass = 0
#IDScalarFieldzyp::phibmass = 0
#IDScalarFieldzyp::STplankmass     = 0.199471140200716338970
#TwopuncturesMatterzyp::STplankmass     = 0.199471140200716338970

#############################################################
# Spacetime Evolution
#############################################################

# The number of points needed in each direction to calculate using
# derivatives.  
GenericFD::stencil_width 	= 3

Kranc2BSSNChi::m                        = 1
Kranc2BSSNChi::lapseAdvection           = 1
Kranc2BSSNChi::gammaDriverLambda        = 0
Kranc2BSSNChi::betaDotAlphaFactor       = 0.75
Kranc2BSSNChi::etaBeta                  = 4 #2
Kranc2BSSNChi::chiBeta                  = 1
Kranc2BSSNChi::gammaDriverLapsePower    = 0
Kranc2BSSNChi::nasaAdvection            = 1
Kranc2BSSNChi::newNASAAdvection         = 1
Kranc2BSSNChi::betatAdvection           = 1
Kranc2BSSNChi::chiEps                   = $chiEps
Kranc2BSSNChi::verbose                  = 0
Kranc2BSSNChi::fd_order                 = "6th"
Kranc2BSSNChi::lapse_condition          = "1 + log 6th"
Kranc2BSSNChi::shift_condition          = "NASA6th"
Kranc2BSSNChi::boundary_condition       = "radiative"
Kranc2BSSNChi::recalculate_constraints  = "vacuum"
#Kranc2BSSNChi::flrwcf  = 1.0
#Kranc2BSSNChi::couple_matter = "yes"
Kranc2BSSNChi::harmonicf  = 2.0
#TmunuBase::timelevels           = 3
#TmunuBase::stress_energy_storage    = "yes"
#TmunuBase::stress_energy_at_RHS     = "yes" #order_time


#EvolveScalarFields::phiaBG               = 0
#EvolveScalarFields::fd_order            = "6th" # "full4th" #
#EvolveScalarFields::boundary_condition  = "none" # "none" #
#EvolveScalarFields::calculate_rho       = "yes"
#EvolveScalarFields::phia_group_bound   = "none"
#EvolveScalarFields::pia_group_bound    = "none"
#EvolveScalarFields::phib_group_bound   = "none"
#EvolveScalarFields::pib_group_bound    = "none"

# This lowers the order of accuracy, but some dissipation might be required
Dissipation::order                 = 3
Dissipation::epsdis                = 0.0
$Dissipation_per_level_lines

Dissipation::vars = "Kranc2BSSNChi::A_group Kranc2BSSNChi::alpha_group Kranc2BSSNChi::beta_group Kranc2BSSNChi::betat_group Kranc2BSSNChi::Gam_group Kranc2BSSNChi::h_group Kranc2BSSNChi::K_group Kranc2BSSNChi::chi_group"


#############################################################
# Boundary conditions
#############################################################

# These specify that no standard CACTUS boundary condition is to be
# applied. These parameters must be present or the Cactus symmetry
# boundary condition will not be applied. The outgoing radiative
# boundary condition provided by Kranc2BSSN is always applied.
Kranc2BSSNChi::A_group_bound   = "none"
Kranc2BSSNChi::alpha_group_bound = "none"
Kranc2BSSNChi::beta_group_bound = "none"
Kranc2BSSNChi::betat_group_bound = "none"
Kranc2BSSNChi::Gam_group_bound = "none"
Kranc2BSSNChi::h_group_bound = "none"
Kranc2BSSNChi::K_group_bound = "none"
Kranc2BSSNChi::chi_group_bound = "none"

#############################################################
# Check for NaNs 
#############################################################

NaNChecker::check_every = 1
NaNChecker::action_if_found = "terminate" #"terminate", "just warn", "abort"
NaNChecker::check_vars = "Kranc2BSSNChi::A_group Kranc2BSSNChi::alpha_group Kranc2BSSNChi::beta_group Kranc2BSSNChi::betat_group Kranc2BSSNChi::chi_group Kranc2BSSNChi::Gam_group Kranc2BSSNChi::h_group Kranc2BSSNChi::K_group"
NaNChecker::verbose = "all"

#############################################################
# ShiftTracker 
#############################################################

#ShiftTracker::x0[0]              = -0.000217
#ShiftTracker::y0[0]              = 0.0
#ShiftTracker::z0[0]              = 0.0
#ShiftTracker::surface_index[1]   = 0

#ShiftTracker::num_trackers       = 1
#ShiftTracker::verbose            = 0
#ShiftTracker::output_every       = 32
#ShiftTracker::interpolator_name  = "Lagrange polynomial interpolation"
#ShiftTracker::interpolator_pars  = "order=4"
#ShiftTracker::beta1_var          = "Kranc2BSSNChi::beta1"
#ShiftTracker::beta2_var          = "Kranc2BSSNChi::beta2"
#ShiftTracker::beta3_var          = "Kranc2BSSNChi::beta3"

#############################################################
# SphericalSurface
#############################################################

SphericalSurface::nsurfaces  = 2
SphericalSurface::maxntheta  = 120
SphericalSurface::maxnphi    = 100

## Apparent Horizons ##
SphericalSurface::ntheta[0]    = 120
SphericalSurface::nphi[0]      = 100
SphericalSurface::ntheta[1]    = 120
SphericalSurface::nphi[1]      = 100

#############################################################
# AHFinder
#############################################################
AHFinderDirect::find_every = $AH_find_every
AHFinderDirect::N_horizons = 1
AHFinderDirect::output_h_every = 0
AHFinderDirect::move_origins = "yes"
AHFinderDirect::verbose_level = "physics details"
AHFinderDirect::run_at_CCTK_POSTSTEP = "yes"
#AHFinderDirect::run_at_CCTK_POSTINITIAL = "yes"
AHFinderDirect::run_at_CCTK_POSTPOSTINITIAL = "yes"
AHFinderDirect::run_at_CCTK_POST_RECOVER_VARIABLES = "yes"

AHFinderDirect::origin_x[1] = 0.
AHFinderDirect::origin_y[1] = 0.
AHFinderDirect::origin_z[1] = 0.
AHFinderDirect::initial_guess__coord_sphere__x_center[1] = 0.
AHFinderDirect::initial_guess__coord_sphere__y_center[1] = 0.
AHFinderDirect::initial_guess__coord_sphere__z_center[1] = 0.
AHFinderDirect::initial_guess__coord_sphere__radius[1] = 0.4
AHFinderDirect::which_surface_to_store_info[1] = 0
AHFinderDirect::reset_horizon_after_not_finding[1] = "no"

#############################################################
# IHSpin
#############################################################

IHSpin::compute_every          = $AH_find_every
IHSpin::num_horizons           = 2
IHSpin::surface_index[0]       = 0
IHSpin::surface_index[1]       = 1
IHSpin::compute_every_individual[0] = $AH_find_every
IHSpin::compute_every_individual[1] = $AH_find_every
IHSpin::interpolator_name      = "Lagrange polynomial interpolation"
IHSpin::interpolator_pars      = "order=4"
IHSpin::verbose = 0

#############################################################
# SphereRad
#############################################################

SphereRad::max_nsurface           = 1
SphereRad::surface_index[0]       = 1
SphereRad::force_position[0]      = "yes"
SphereRad::mass[0]		  = $mass
SphereRad::radius_surface[0]      = 0.6
SphereRad::verbose                = 0

#############################################################
# Wave extraction
#############################################################

WeylScal4::offset                    = 1e-8
WeylScal4::fd_order                  = "4th"
WeylScal4::WeylScal4_psis_calc_4th_calc_every = 1
WeylScal4::WeylScal4_psis_calc_4th_calc_offset = 0
WeylScal4::verbose                   = 0

Multipole::out_every                = $every_coarse
Multipole::nradii                   = $num_extraction_spheres
$Multipole_radius_lines
Multipole::variables                = "Kranc2BSSNChi::K{sw=0 name='pia'}"
#WeylScal4::Psi4r{sw=-2 cmplx='WeylScal4::Psi4i'}
Multipole::verbose                  = 0
Multipole::l_max                    = 4
#Multipole::m_mode                   = 4
Multipole::ntheta                   = 120
Multipole::nphi                     = 240

#############################################################
## scalarAnalysis
##############################################################
