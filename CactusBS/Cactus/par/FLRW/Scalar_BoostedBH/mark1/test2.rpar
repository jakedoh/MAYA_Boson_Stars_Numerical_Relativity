#scalarAnalysis::maxntheta             = 60
#scalarAnalysis:: maxnphi              = 120

#############################################################
# ADM Energy
#############################################################

ADM_EJP::number_of_detectors      = $num_extraction_spheres
$ADM_EJP_radius_lines
ADM_EJP::verbose                  = 0
ADM_EJP::interpolator_name        = "Lagrange polynomial interpolation"
ADM_EJP::interpolator_pars        = "order=4"
ADM_EJP::ntheta                   = 120
ADM_EJP::nphi                     = 240

#############################################################
# Output
#############################################################

IO::out_dir                   = \$parfile
IO::out_fileinfo              = "all"


CarpetIOScalar::outScalar_every      = 1
CarpetIOScalar::outScalar_reductions = " minimum maximum norm2" #
CarpetIOScalar::outScalar_vars       = "
                                        Kranc2BSSNChi::beta1
                                        Kranc2BSSNChi::alpha
                                        Kranc2BSSNChi::chi
                                        Kranc2BSSNChi::bssnham
                                        Kranc2BSSNChi::K"


Kranc2BSSNChi::constraintsfdorder = 4

CarpetIOBasic::outInfo_every         = 32
CarpetIOBasic::outInfo_vars          = "
                                        Kranc2BSSNChi::chi
                                        Kranc2BSSNChi::alpha
                                        Kranc2BSSNChi::bssnham
        "
IOASCII::out1D_every          = $out1d
IOASCII::out1D_d                     = no
CarpetIOASCII::out1D_x               = "no"
CarpetIOASCII::out1D_y               = "no"
CarpetIOASCII::out1D_z               = "no"
CarpetIOASCII::out1D_vars            = "
                                        Kranc2BSSNChi::alpha
                                        Kranc2BSSNChi::beta1
                                        Kranc2BSSNChi::chi
                                        Kranc2BSSNChi::K
                                        ADMBase::metric
                                        Kranc2BSSNChi::A_group
                                        Kranc2BSSNChi::bssnham"
                                        #ADMBase::metric
                                        #ADMBase::alp
                                        #WeylScal4::Psi4r

carpetioascii::out3D_ghosts   = "yes"

CarpetIOHDF5::compression_level      = 0
CarpetIOHDF5::out2D_every            = $out2d
CarpetIOHDF5::out2D_xy               = "yes"
CarpetIOHDF5::out2D_xz               = "no"
CarpetIOHDF5::out2D_yz               = "no"
CarpetIOHDF5::out2D_vars           = "Kranc2BSSNChi::bssnham 
                                      Kranc2BSSNChi::bssnmom_group 
                                      Kranc2BSSNChi::alpha
                                      Kranc2BSSNChi::beta1"

CarpetIOHDF5::out_every              = $out3d
CarpetIOHDF5::out_vars               = "Kranc2BSSNChi::alpha Kranc2BSSNChi::bssnham Kranc2BSSNChi::bssnmom_group"

#############################################################
### Checkpoint and Recovery
###############################################################

CarpetIOHDF5::checkpoint            = "yes"
IO::checkpoint_every_walltime_hours = 11
IO::checkpoint_keep                 = 1
IO::checkpoint_dir                  = \$parfile
IO::checkpoint_on_terminate         = "yes"

IO::recover                         = "autoprobe"
IO::recover_dir                     = \$parfile
IO::recover_and_remove              = "no"

EOF

my $filename = "$0";
$filename =~ s/\.rpar/.par/g;

open(OUT,">$filename");
print OUT "$lines";
close(OUT);

