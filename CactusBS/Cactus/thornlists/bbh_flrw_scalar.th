# Various thorns from LSU
!TARGET   = $ARR
!TYPE     = svn
#!URL      = https://svn.cct.lsu.edu/repos/numrel/$1/$2/trunk
!URL      = https://svn.cct.lsu.edu/repos/numrel/$1/$2/branches/$ET_RELEASE
