!TYPE     = git
!URL      = git://github.com/ianhinder/Kranc.git
#!AUTH_URL = git@github.com:ianhinder/Kranc.git
!REPO_BRANCH = $ET_RELEASE
!REPO_PATH= Auxiliary/Cactus
