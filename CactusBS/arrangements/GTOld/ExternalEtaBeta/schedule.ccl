STORAGE: exetaBeta_group[other_timelevels]
schedule ExternalEtaBeta_Startup at STARTUP
{
  LANG: C
  OPTIONS: meta
} "create banner"

schedule ExternalEtaBeta_RegisterSymmetries in SymmetryRegister
{
  LANG: C
  OPTIONS: meta
} "register symmetries"

if (CCTK_EQUALS(rescale_etaBeta, "yes"))
{
  schedule eta_beta_rescale_etaBeta_calc at INITIAL after etaBeta_calc_etaBeta as rescale_etaBeta
  {
    LANG: C
    READS: grid::r(Everywhere)
    READS: ExternalEtaBeta::exetaBeta(Everywhere)
    WRITES: ExternalEtaBeta::exetaBeta(Everywhere)
  } "eta_beta_rescale_etaBeta_calc"
}

if (CCTK_EQUALS(rescale_etaBeta, "yes"))
{
  schedule eta_beta_rescale_etaBeta_calc in MoL_CalcRHS after etaBeta_calc_etaBeta as rescale_etaBeta
  {
    LANG: C
    READS: grid::r(Everywhere)
    READS: ExternalEtaBeta::exetaBeta(Everywhere)
    WRITES: ExternalEtaBeta::exetaBeta(Everywhere)
  } "eta_beta_rescale_etaBeta_calc"
}

if (CCTK_EQUALS(rescale_etaBeta, "tanh"))
