    LANG: C
    READS: grid::x(Everywhere)
    READS: grid::y(Everywhere)
    READS: grid::z(Everywhere)
    WRITES: ExternalEtaBeta::exetaBeta(Everywhere)
  } "eta_beta_calc_etaBeta_exp"
}

