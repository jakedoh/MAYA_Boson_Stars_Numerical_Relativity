    WRITES: ExternalEtaBeta::exetaBeta(Everywhere)
  } "eta_beta_rescale_etaBeta_tanh_calc"
}

if (CCTK_EQUALS(etaBeta_form, "polynomial"))
{
  schedule eta_beta_calc_etaBeta_poly at INITIAL after ShiftTracker_Set_SphericalSurface as etaBeta_calc_etaBeta
  {
    LANG: C
    READS: grid::x(Everywhere)
    READS: grid::y(Everywhere)
    READS: grid::z(Everywhere)
    WRITES: ExternalEtaBeta::exetaBeta(Everywhere)
  } "eta_beta_calc_etaBeta_poly"
}

if (CCTK_EQUALS(etaBeta_form, "polynomial"))
{
  schedule eta_beta_calc_etaBeta_poly in MoL_CalcRHS before bssn_shift as etaBeta_calc_etaBeta
  {
    LANG: C
    READS: grid::x(Everywhere)
    READS: grid::y(Everywhere)
    READS: grid::z(Everywhere)
    WRITES: ExternalEtaBeta::exetaBeta(Everywhere)
  } "eta_beta_calc_etaBeta_poly"
}

if (CCTK_EQUALS(etaBeta_form, "exponential"))
