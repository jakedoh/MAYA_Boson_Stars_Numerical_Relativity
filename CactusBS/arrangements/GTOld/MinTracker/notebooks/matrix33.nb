Cell[CellGroupData[{
Cell["C form for 3 by 3 matrix inversion", "Section",
 CellChangeTimes->{{3.411756966491506*^9, 3.411756974468676*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"mat", "=", 
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{"m", "[", 
     RowBox[{"i", ",", "j"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"i", ",", "1", ",", "3"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"j", ",", "1", ",", "3"}], "}"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"m", "[", 
      RowBox[{"1", ",", "1"}], "]"}], ",", 
     RowBox[{"m", "[", 
      RowBox[{"1", ",", "2"}], "]"}], ",", 
     RowBox[{"m", "[", 
      RowBox[{"1", ",", "3"}], "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"m", "[", 
      RowBox[{"2", ",", "1"}], "]"}], ",", 
     RowBox[{"m", "[", 
      RowBox[{"2", ",", "2"}], "]"}], ",", 
     RowBox[{"m", "[", 
      RowBox[{"2", ",", "3"}], "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"m", "[", 
      RowBox[{"3", ",", "1"}], "]"}], ",", 
     RowBox[{"m", "[", 
      RowBox[{"3", ",", "2"}], "]"}], ",", 
     RowBox[{"m", "[", 
      RowBox[{"3", ",", "3"}], "]"}]}], "}"}]}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"d", "=", 
  RowBox[{"Det", "[", "mat", "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"-", 
    RowBox[{"m", "[", 
     RowBox[{"1", ",", "3"}], "]"}]}], " ", 
   RowBox[{"m", "[", 
    RowBox[{"2", ",", "2"}], "]"}], " ", 
   RowBox[{"m", "[", 
    RowBox[{"3", ",", "1"}], "]"}]}], "+", 
  RowBox[{
   RowBox[{"m", "[", 
    RowBox[{"1", ",", "2"}], "]"}], " ", 
   RowBox[{"m", "[", 
    RowBox[{"2", ",", "3"}], "]"}], " ", 
   RowBox[{"m", "[", 
    RowBox[{"3", ",", "1"}], "]"}]}], "+", 
  RowBox[{
   RowBox[{"m", "[", 
    RowBox[{"1", ",", "3"}], "]"}], " ", 
   RowBox[{"m", "[", 
    RowBox[{"2", ",", "1"}], "]"}], " ", 
   RowBox[{"m", "[", 
    RowBox[{"3", ",", "2"}], "]"}]}], "-", 
  RowBox[{
   RowBox[{"m", "[", 
    RowBox[{"1", ",", "1"}], "]"}], " ", 
   RowBox[{"m", "[", 
    RowBox[{"2", ",", "3"}], "]"}], " ", 
   RowBox[{"m", "[", 
    RowBox[{"3", ",", "2"}], "]"}]}], "-", 
  RowBox[{
   RowBox[{"m", "[", 
    RowBox[{"1", ",", "2"}], "]"}], " ", 
   RowBox[{"m", "[", 
    RowBox[{"2", ",", "1"}], "]"}], " ", 
   RowBox[{"m", "[", 
    RowBox[{"3", ",", "3"}], "]"}]}], "+", 
  RowBox[{
   RowBox[{"m", "[", 
    RowBox[{"1", ",", "1"}], "]"}], " ", 
   RowBox[{"m", "[", 
    RowBox[{"2", ",", "2"}], "]"}], " ", 
   RowBox[{"m", "[", 
    RowBox[{"3", ",", "3"}], "]"}]}]}]], "Output"]
}, Open  ]],

Cell[BoxData[
 RowBox[{
  RowBox[{"toC", "[", "x_", "]"}], ":=", "\[IndentingNewLine]", 
  RowBox[{"StringReplace", "[", 
   RowBox[{
    RowBox[{"ToString", "[", 
     RowBox[{"CForm", "[", 
      RowBox[{"x", "/.", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"a_", "*", "a_"}], "\[Rule]", 
          RowBox[{"SQR", "[", "a", "]"}]}], ",", 
         RowBox[{
          RowBox[{"m", "[", 
           RowBox[{"i_", ",", "j_"}], "]"}], ":>", 
          RowBox[{"\"\<m[\>\"", "<>", 
           RowBox[{"ToString", "[", 
            RowBox[{"i", "-", "1"}], "]"}], "<>", "\"\<][\>\"", "<>", 
           RowBox[{"ToString", "[", 
            RowBox[{"j", "-", "1"}], "]"}], "<>", "\"\<]\>\""}]}]}], "}"}]}], 
      "]"}], "]"}], ",", 
    RowBox[{"\"\<\\\"\>\"", "->", "\"\<\>\""}]}], "]"}]}]], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"dExpr", "=", 
  RowBox[{"ToString", "[", 
   RowBox[{"toC", "[", "d", "]"}], "]"}]}]], "Input"],

Cell[BoxData["\<\"-(m[0][2]*m[1][1]*m[2][0]) + m[0][1]*m[1][2]*m[2][0] + \
m[0][2]*m[1][0]*m[2][1] - m[0][0]*m[1][2]*m[2][1] - m[0][1]*m[1][0]*m[2][2] + \
m[0][0]*m[1][1]*m[2][2]\"\>"], "Output"]
}, Open  ]],

