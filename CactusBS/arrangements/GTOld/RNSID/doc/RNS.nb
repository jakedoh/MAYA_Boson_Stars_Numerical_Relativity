   3.603174718536438*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{"gij", "=", 
   RowBox[{"{", " ", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{"\[Gamma]", "-", "\[Rho]"}]], 
         SuperscriptBox["\[Omega]", "2"], 
         SuperscriptBox["r", "2"], 
         SuperscriptBox[
          RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}], "-", " ", 
