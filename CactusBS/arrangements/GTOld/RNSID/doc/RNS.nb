  3.581934607041799*^9, 3.581934614678996*^9}, {3.5819349900547323`*^9, 
  3.581934991020878*^9}, {3.603187510097539*^9, 3.60318752352106*^9}, {
  3.603187832150483*^9, 3.603187848734022*^9}}],

Cell["\<\
Create a spatial metric with Coordinate - dependent metric potentials, \
introducing the variable change \[Sigma] = \[Gamma]-\[Rho] with additional \
introduction of functional dependence\
\>", "Text",
 CellChangeTimes->{{3.581937417854555*^9, 3.581937449689299*^9}, {
  3.603180339282419*^9, 3.603180353546156*^9}, {3.6031809352693787`*^9, 
  3.603180947125424*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{"coordvars", "=", 
   RowBox[{"{", 
    RowBox[{"x", ",", "y", ",", "z"}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sTof", ":=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"\[Gamma]", "-", "\[Rho]"}], "\[Rule]", 
      RowBox[{"\[Sigma]", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}]}], ",", 
     RowBox[{"\[Gamma]", "\[Rule]", 
      RowBox[{"\[Gamma]", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}]}], " ", ",", 
     RowBox[{"\[Rho]", "\[Rule]", 
      RowBox[{"\[Rho]", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}]}], ",", " ", 
     RowBox[{"\[Alpha]", "\[Rule]", 
      RowBox[{"\[Alpha]", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}]}], ",", " ", 
     RowBox[{"\[Omega]", "\[Rule]", 
      RowBox[{"\[Omega]", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}]}], ",", " ", 
     RowBox[{"\[Sigma]", "\[Rule]", " ", 
      RowBox[{"\[Sigma]", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}]}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Gamma]ijc", "=", 
   RowBox[{"\[Gamma]ij", "/.", "sTof"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"u\[Gamma]ijc", "=", 
