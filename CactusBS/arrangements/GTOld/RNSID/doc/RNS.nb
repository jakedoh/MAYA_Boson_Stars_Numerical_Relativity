Cell[BoxData[
 RowBox[{"baryonmass", "=", " ", 
  RowBox[{"2", "\[Pi]", " ", 
   SuperscriptBox["rStar", "3"], " ", 
   RowBox[{"NIntegrate", "[", " ", 
    RowBox[{
     RowBox[{
      FractionBox[
       RowBox[{
        RowBox[{"(", " ", 
