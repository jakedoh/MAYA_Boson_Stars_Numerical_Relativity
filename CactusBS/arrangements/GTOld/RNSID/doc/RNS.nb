Cell[BoxData[{
 RowBox[{"The", " ", "Extrinsic", " ", "Curvature", " ", "here", " ", "is", 
  " ", "constructed", " ", "as", " ", 
  RowBox[{"(", 
   RowBox[{"Alcubierre", " ", 
    RowBox[{"Eq", ".", " ", "2.3"}], ".12"}], 
   ")"}]}], "\[IndentingNewLine]", 
 RowBox[{
  SubscriptBox["K", "ij"], "=", 
  RowBox[{
   RowBox[{
    FractionBox["1", 
     RowBox[{"2", "\[Alpha]"}]], 
    RowBox[{"(", " ", 
     RowBox[{
      RowBox[{
       SubscriptBox["\[PartialD]", "i"], 
       SubscriptBox["\[Beta]", "j"]}], "+", " ", 
      RowBox[{
       SubscriptBox["\[PartialD]", "j"], 
       SubscriptBox["\[Beta]", "i"]}], "-", 
      RowBox[{"2", 
       SubscriptBox["\[Beta]", "k"], 
       SuperscriptBox[
        SubscriptBox["\[CapitalGamma]", "ij"], "k"]}]}], ")"}]}], " ", "=", 
   RowBox[{
    FractionBox["1", "\[Alpha]"], 
    RowBox[{"(", " ", 
     RowBox[{
      RowBox[{
       SubscriptBox["\[PartialD]", 
        RowBox[{"(", "i"}]], 
       SubscriptBox["\[Beta]", 
        RowBox[{"j", ")"}]]}], "-", 
      RowBox[{
       SubscriptBox["\[Beta]", "k"], 
       SuperscriptBox[
        SubscriptBox["\[CapitalGamma]", "ij"], "k"]}]}], ")"}]}]}]}]}], "Text",\

