Cell["\<\
Find analytic derivatives to convert to (x, y, z) coordinates\
\>", "Text",
 CellChangeTimes->{{3.604922670397357*^9, 3.6049226972707233`*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"sr", "[", "r_", "]"}], ":=", 
   FractionBox["r", 
    RowBox[{"r", "+", "rStar"}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"s", "[", 
    RowBox[{"x_", ",", "y_", ",", "z_"}], "]"}], ":=", " ", 
   FractionBox[
    RowBox[{"Sqrt", "[", 
     RowBox[{
      SuperscriptBox["x", "2"], "+", 
      SuperscriptBox["y", "2"], "+", 
      SuperscriptBox["z", "2"]}], "]"}], 
    RowBox[{
     RowBox[{"Sqrt", "[", 
      RowBox[{
       SuperscriptBox["x", "2"], "+", 
       SuperscriptBox["y", "2"], "+", 
       SuperscriptBox["z", "2"]}], "]"}], "+", "rStar"}]]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Mu]", "[", 
    RowBox[{"x_", ",", "y_", ",", "z_"}], "]"}], ":=", 
   FractionBox["z", 
    RowBox[{"Sqrt", "[", 
     RowBox[{
      SuperscriptBox["x", "2"], "+", 
      SuperscriptBox["y", "2"], "+", 
      SuperscriptBox["z", "2"]}], "]"}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dsdx", "=", 
   RowBox[{"Simplify", "[", 
    RowBox[{"D", "[", 
     RowBox[{
      RowBox[{"s", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}], ",", "x"}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dsdy", "=", 
   RowBox[{"Simplify", "[", 
    RowBox[{"D", "[", 
     RowBox[{
      RowBox[{"s", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}], ",", "y"}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dsdz", "=", 
   RowBox[{"Simplify", "[", 
    RowBox[{"D", "[", 
     RowBox[{
      RowBox[{"s", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}], ",", "z"}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"d\[Mu]dx", "=", 
   RowBox[{"Simplify", "[", 
    RowBox[{"D", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}], ",", "x"}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"d\[Mu]dy", "=", 
   RowBox[{"Simplify", "[", 
    RowBox[{"D", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}], ",", "y"}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"d\[Mu]dz", "=", 
   RowBox[{"Simplify", "[", 
    RowBox[{"D", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}], ",", "z"}], "]"}], "]"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.6049233464457808`*^9, 3.604923357741969*^9}, {
  3.6049235924607887`*^9, 3.604923595588669*^9}}],

Cell["\<\
Create the interpolating functions and clear the original list data\
\>", "Text",
 CellChangeTimes->{{3.604991042841737*^9, 3.604991061975066*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Rho]s\[Mu]", "=", 
   RowBox[{"Interpolation", "[", " ", 
    RowBox[{"rnsSoln", "\[LeftDoubleBracket]", 
     RowBox[{";;", ",", 
      RowBox[{"{", 
       RowBox[{"3", ",", "4", ",", "5"}], "}"}]}], "\[RightDoubleBracket]"}], 
    " ", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Gamma]s\[Mu]", "=", 
   RowBox[{"Interpolation", "[", " ", 
    RowBox[{"rnsSoln", "\[LeftDoubleBracket]", 
     RowBox[{";;", ",", 
      RowBox[{"{", 
       RowBox[{"3", ",", "4", ",", "6"}], "}"}]}], "\[RightDoubleBracket]"}], 
    " ", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Alpha]s\[Mu]", "=", 
   RowBox[{"Interpolation", "[", " ", 
    RowBox[{"rnsSoln", "\[LeftDoubleBracket]", 
     RowBox[{";;", ",", 
      RowBox[{"{", 
       RowBox[{"3", ",", "4", ",", "7"}], "}"}]}], "\[RightDoubleBracket]"}], 
    " ", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Omega]s\[Mu]", "=", 
    RowBox[{"Interpolation", "[", " ", 
     RowBox[{"rnsSoln", "\[LeftDoubleBracket]", 
      RowBox[{";;", ",", 
       RowBox[{"{", 
        RowBox[{"3", ",", "4", ",", "8"}], "}"}]}], "\[RightDoubleBracket]"}],
      " ", "]"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"es\[Mu]", "=", 
   RowBox[{"Interpolation", "[", " ", 
    RowBox[{"rnsSoln", "\[LeftDoubleBracket]", 
     RowBox[{";;", ",", 
      RowBox[{"{", 
       RowBox[{"3", ",", "4", ",", "9"}], "}"}]}], "\[RightDoubleBracket]"}], 
    " ", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ps\[Mu]", "=", 
   RowBox[{"Interpolation", "[", " ", 
    RowBox[{"rnsSoln", "\[LeftDoubleBracket]", 
     RowBox[{";;", ",", 
      RowBox[{"{", 
       RowBox[{"3", ",", "4", ",", "10"}], "}"}]}], "\[RightDoubleBracket]"}],
     " ", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"hs\[Mu]", "=", 
   RowBox[{"Interpolation", "[", " ", 
    RowBox[{"rnsSoln", "\[LeftDoubleBracket]", 
