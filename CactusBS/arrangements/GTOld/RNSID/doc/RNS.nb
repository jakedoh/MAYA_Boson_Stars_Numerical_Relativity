Notebook[{

Cell[CellGroupData[{
Cell["Rotating Neutron Star", "Title",
 CellChangeTimes->{{3.495378048077984*^9, 3.495378050604636*^9}}],

Cell["Quit Kernel before executing another top level section!", "Subtitle",
 CellChangeTimes->{{3.603191853158494*^9, 3.603191884600761*^9}}],

Cell[CellGroupData[{

Cell["Rotating NS, Default Polar Spherical", "Section",
 CellChangeTimes->{{3.603173807714387*^9, 3.603173815968692*^9}, 
   3.603173849016062*^9}],

Cell[TextData[{
 "The metric as solved for by the RNSID code is of the form :\n",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["ds", "2"], "=", 
   RowBox[{
    RowBox[{
     RowBox[{"-", " ", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"\[Gamma]", "+", "\[Rho]"}]]}], 
     SuperscriptBox["dt", "2"]}], " ", "+", " ", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"\[Gamma]", "-", "\[Rho]"}]], 
     SuperscriptBox["r", "2"], 
     SuperscriptBox[
      RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"], 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"d\[Phi]", " ", "-", 
        RowBox[{"\[Omega]", " ", "dt"}]}], ")"}], "2"]}], " ", "+", " ", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"2", "\[Alpha]"}]], 
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["dr", "2"], "+", 
       RowBox[{
        SuperscriptBox["r", "2"], 
        SuperscriptBox["d\[Theta]", "2"]}]}], ")"}]}]}]}]], "Input",
  CellChangeTimes->{{3.5819204070788794`*^9, 3.581920536001099*^9}, {
    3.5819207269923964`*^9, 3.581920744880402*^9}, {3.5819208169274893`*^9, 
    3.5819208604604797`*^9}, 3.5819454748562307`*^9, {3.602335769971574*^9, 
    3.602335787429965*^9}}]
}], "Text",
 CellChangeTimes->{{3.5819203883810787`*^9, 3.58192040523973*^9}, 
   3.581920544924983*^9, {3.603179113788525*^9, 3.603179124319415*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"lineElement", "[", 
    RowBox[{
    "r_", ",", "\[Theta]_", ",", "\[Phi]_", ",", "\[Gamma]_", ",", "\[Rho]_", 
     ",", "\[Alpha]_", ",", "\[Omega]_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{
     RowBox[{"-", " ", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"\[Gamma]", "+", "\[Rho]"}]]}], 
     SuperscriptBox["dt", "2"]}], " ", "+", " ", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"\[Gamma]", "-", "\[Rho]"}]], 
     SuperscriptBox["r", "2"], 
     SuperscriptBox[
      RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"], 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"d\[Phi]", " ", "-", 
        RowBox[{"\[Omega]", " ", "dt"}]}], ")"}], "2"]}], " ", "+", " ", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"2", "\[Alpha]"}]], 
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["dr", "2"], "+", 
       RowBox[{
        SuperscriptBox["r", "2"], 
        SuperscriptBox["d\[Theta]", "2"]}]}], ")"}]}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.5819204070788794`*^9, 3.581920536001099*^9}, {
   3.5819207269923964`*^9, 3.581920744880402*^9}, {3.5819208169274893`*^9, 
   3.5819208604604797`*^9}, 3.5819454748562307`*^9, {3.602335769971574*^9, 
   3.602335787429965*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{"gij", "=", 
   RowBox[{"{", " ", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{"\[Gamma]", "-", "\[Rho]"}]], 
         SuperscriptBox["\[Omega]", "2"], 
         SuperscriptBox["r", "2"], 
         SuperscriptBox[
          RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}], "-", " ", 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"\[Gamma]", "+", "\[Rho]"}]]}], ",", "0", ",", "0", ",", 
       RowBox[{
        RowBox[{"-", 
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{"\[Gamma]", "-", "\[Rho]"}]]}], "\[Omega]", " ", 
        SuperscriptBox["r", "2"], 
        SuperscriptBox[
         RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}]}], "}"}], ",", 
     "\[IndentingNewLine]", "         ", 
     RowBox[{"{", 
      RowBox[{"0", ",", " ", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"2", "\[Alpha]"}]], ",", "0", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", 
       RowBox[{
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"2", "\[Alpha]"}]], " ", 
        SuperscriptBox["r", "2"]}], ",", "0"}], "}"}], ",", 
     "\[IndentingNewLine]", "         ", 
     RowBox[{"{", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"-", " ", 
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{"\[Gamma]", "-", "\[Rho]"}]]}], "\[Omega]", " ", 
        SuperscriptBox["r", "2"], 
        SuperscriptBox[
         RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}], ",", "0", ",", "0", 
       ",", 
       RowBox[{
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"\[Gamma]", "-", "\[Rho]"}]], 
        SuperscriptBox["r", "2"], 
        SuperscriptBox[
         RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}]}], "}"}]}], " ", 
    "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ugij", "=", 
   RowBox[{"Inverse", "[", "gij", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Gamma]ij", "=", 
   RowBox[{"gij", "\[LeftDoubleBracket]", 
    RowBox[{
     RowBox[{"2", ";;", "4"}], ",", 
     RowBox[{"2", ";;", "4"}]}], "\[RightDoubleBracket]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"u\[Gamma]ij", "=", 
   RowBox[{"Inverse", "[", "\[Gamma]ij", "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.603174695600717*^9, 3.603174868430892*^9}, {
  3.6031749466760883`*^9, 3.6031749472920322`*^9}, {3.60317615303133*^9, 
  3.6031761539185877`*^9}, {3.6031765262190228`*^9, 3.603176591393083*^9}, {
  3.603176656999364*^9, 3.6031766816208153`*^9}, {3.60317672029213*^9, 
  3.603176744812722*^9}}],

