Cell[CellGroupData[{

Cell["Overview of Solution", "Subsection",
 CellChangeTimes->{{3.615633661058406*^9, 3.615633666313122*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{
  "We", " ", "only", " ", "need", " ", "the", " ", "hydro", " ", "portion", 
   " ", "of", " ", "the", " ", "solution", " ", "for", " ", "calculating", 
   " ", 
   SuperscriptBox["j", "i"]}], ",", Cell["the momentum density,", "Text",
   CellChangeTimes->{{3.604139425876978*^9, 
    3.604139435055073*^9}}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"so", " ", "calculate"}], ",", " ", 
  RowBox[{
  "then", " ", "clear", " ", "the", " ", "original", " ", "interpolating", 
   " ", "functions"}]}]}], "Text",
 CellChangeTimes->{{3.604921455758297*^9, 3.604921487598298*^9}, {
  3.604923181991523*^9, 3.604923190718721*^9}}],

Cell["First, set rules to calculate interesting quantities", "Text",
 CellChangeTimes->{{3.615633893659522*^9, 3.615633921585575*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"j\[Phi]", "[", 
    RowBox[{"s_", ",", "\[Mu]_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"(", " ", 
     FractionBox[
      RowBox[{
       RowBox[{"es\[Mu]", "[", 
        RowBox[{"s", ",", "\[Mu]"}], "]"}], "+", 
       RowBox[{"ps\[Mu]", "[", 
        RowBox[{"s", ",", "\[Mu]"}], "]"}]}], 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{"v2s\[Mu]", "[", 
         RowBox[{"s", ",", "\[Mu]"}], "]"}]}], ")"}]], ")"}], 
    RowBox[{"Sqrt", "[", 
     RowBox[{"v2s\[Mu]", "[", 
      RowBox[{"s", ",", "\[Mu]"}], "]"}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Beta]y", "[", "x_", "]"}], ":=", " ", 
   RowBox[{
    RowBox[{"-", "x"}], " ", 
    RowBox[{"\[Omega]s\[Mu]", "[", 
     RowBox[{
      RowBox[{"sr", "[", "x", "]"}], ",", "0"}], "]"}], " ", 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "2"}], " ", 
         RowBox[{"\[Alpha]s\[Mu]", "[", 
          RowBox[{
           RowBox[{"sr", "[", "x", "]"}], ",", "0"}], "]"}]}], "+", 
        RowBox[{"\[Gamma]s\[Mu]", "[", 
         RowBox[{
          RowBox[{"sr", "[", "x", "]"}], ",", "0"}], "]"}], "-", 
        RowBox[{"\[Rho]s\[Mu]", "[", 
         RowBox[{
          RowBox[{"sr", "[", "x", "]"}], ",", "0"}], "]"}]}], ")"}], "*", 
      "0.5"}]]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"magv", "[", "r_", "]"}], ":=", " ", 
   RowBox[{"Sqrt", "[", 
    RowBox[{"v2s\[Mu]", "[", 
     RowBox[{
      RowBox[{"sr", "[", "r", "]"}], ",", "0"}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
