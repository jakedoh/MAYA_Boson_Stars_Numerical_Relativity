Cell["Derivatives of \[Omega]", "Text",
 CellChangeTimes->{{3.619326550519438*^9, 3.619326570869227*^9}}],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"d\[Omega]ds", "=", 
   RowBox[{"D", "[", 
    RowBox[{
     RowBox[{"\[Omega]s\[Mu]", "[", 
      RowBox[{"s", ",", "\[Mu]"}], "]"}], ",", "s"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"d\[Omega]d\[Mu]", "=", 
   RowBox[{"D", "[", 
    RowBox[{
     RowBox[{"\[Omega]s\[Mu]", "[", 
      RowBox[{"s", ",", "\[Mu]"}], "]"}], ",", "\[Mu]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", " ", 
  RowBox[{
   RowBox[{"d\[Omega]ds", "[", 
    RowBox[{"s", ",", "0"}], "]"}], ",", 
   RowBox[{"d\[Omega]d\[Mu]", "[", 
    RowBox[{"s", ",", "0"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"s", ",", "0", ",", "0.5"}], "}"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.619326574754435*^9, 3.6193266417435083`*^9}}],

Cell[BoxData[
 RowBox[{
  StyleBox[
   RowBox[{"Plot", "::", "nonopt"}], "MessageName"], 
  RowBox[{
  ":", " "}], "\<\"Options expected (instead of \[NoBreak]\\!\\({s, 0, \
0.5`}\\)\[NoBreak]) beyond position \[NoBreak]\\!\\(2\\)\[NoBreak] in \
\[NoBreak]\\!\\(Plot[\\(\\(\\(\\(d\[Omega]ds[\\(\\(s, 0\\)\\)]\\)\\), \\(\\(d\
\[Omega]d\[Mu][\\(\\(s, 0\\)\\)]\\)\\), \\(\\({s, 0, 0.5`}\\)\\)\\)\\)]\\)\
\[NoBreak]. An option must be a rule or a list of rules. \
\\!\\(\\*ButtonBox[\\\"\[RightSkeleton]\\\", ButtonStyle->\\\"Link\\\", \
ButtonFrame->None, ButtonData:>\\\"paclet:ref/message/General/nonopt\\\", \
ButtonNote -> \\\"Plot::nonopt\\\"]\\)\"\>"}]], "Message", "MSG",
 CellChangeTimes->{3.619326701910694*^9}],

