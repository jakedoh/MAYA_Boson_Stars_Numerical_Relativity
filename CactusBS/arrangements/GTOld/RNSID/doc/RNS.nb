         RowBox[{"\[Gamma]", "+", "\[Rho]"}]]}], ",", "0", ",", "0", ",", 
       RowBox[{
        RowBox[{"-", 
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{"\[Alpha]", "+", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"\[Gamma]", "-", "\[Rho]"}], ")"}], "/", "2"}]}]]}], 
        "\[Omega]", " ", 
        SuperscriptBox["r", "2"], 
        SuperscriptBox[
         RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}]}], "}"}], ",", 
     "\[IndentingNewLine]", "         ", 
     RowBox[{"{", 
      RowBox[{"0", ",", " ", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"2", "\[Alpha]"}]], ",", "0", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", 
       RowBox[{
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"2", "\[Alpha]"}]], " ", 
        SuperscriptBox["r", "2"]}], ",", "0"}], "}"}], ",", 
     "\[IndentingNewLine]", "         ", 
     RowBox[{"{", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"-", " ", 
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{"\[Alpha]", "+", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"\[Gamma]", "-", "\[Rho]"}], ")"}], "/", "2"}]}]]}], 
        "\[Omega]", " ", 
        SuperscriptBox["r", "2"], 
        SuperscriptBox[
         RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}], ",", "0", ",", "0", 
       ",", 
       RowBox[{
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"2", "\[Alpha]"}]], 
        SuperscriptBox["r", "2"], 
        SuperscriptBox[
         RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}]}], "}"}]}], " ", 
    "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ugij", "=", 
   RowBox[{"Inverse", "[", "gij", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Gamma]ij", "=", 
   RowBox[{"gij", "\[LeftDoubleBracket]", 
    RowBox[{
     RowBox[{"2", ";;", "4"}], ",", 
     RowBox[{"2", ";;", "4"}]}], "\[RightDoubleBracket]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"u\[Gamma]ij", "=", 
   RowBox[{"Inverse", "[", "\[Gamma]ij", "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.603174695600717*^9, 3.603174868430892*^9}, {
  3.6031749466760883`*^9, 3.6031749472920322`*^9}, {3.60317615303133*^9, 
