Cell["\<\
Create the derivatives of these metric potentials in (s,\[Mu]) space \
\>", "Text",
 CellChangeTimes->{{3.604922735040566*^9, 3.6049227543573647`*^9}, {
  3.604922982524001*^9, 3.6049229878028717`*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{"d\[Rho]ds", "=", 
   RowBox[{
    RowBox[{"Derivative", "[", 
     RowBox[{"1", ",", "0"}], "]"}], "[", "\[Rho]s\[Mu]", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"d\[Rho]d\[Mu]", "=", 
   RowBox[{
    RowBox[{"Derivative", "[", 
     RowBox[{"0", ",", "1"}], "]"}], "[", "\[Rho]s\[Mu]", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"d\[Gamma]ds", "=", 
   RowBox[{
    RowBox[{"Derivative", "[", 
     RowBox[{"1", ",", "0"}], "]"}], "[", "\[Gamma]s\[Mu]", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"d\[Gamma]d\[Mu]", "=", 
   RowBox[{
    RowBox[{"Derivative", "[", 
     RowBox[{"0", ",", "1"}], "]"}], "[", "\[Gamma]s\[Mu]", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"d\[Alpha]ds", "=", 
   RowBox[{
    RowBox[{"Derivative", "[", 
     RowBox[{"1", ",", "0"}], "]"}], "[", "\[Alpha]s\[Mu]", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"d\[Alpha]d\[Mu]", "=", 
   RowBox[{
    RowBox[{"Derivative", "[", 
     RowBox[{"0", ",", "1"}], "]"}], "[", "\[Alpha]s\[Mu]", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"d\[Omega]ds", "=", 
   RowBox[{
    RowBox[{"Derivative", "[", 
     RowBox[{"1", ",", "0"}], "]"}], "[", "\[Alpha]s\[Mu]", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"d\[Omega]d\[Mu]", "=", 
    RowBox[{
     RowBox[{"Derivative", "[", 
      RowBox[{"0", ",", "1"}], "]"}], "[", "\[Alpha]s\[Mu]", "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"d\[Rho]dx", "^", "i"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"d\[Rho]dx", "[", 
    RowBox[{"x_", ",", "y_", ",", "z_"}], "]"}], ":=", " ", 
   RowBox[{
    RowBox[{"dsdx", " ", 
     RowBox[{"d\[Rho]ds", "[", " ", 
      RowBox[{
