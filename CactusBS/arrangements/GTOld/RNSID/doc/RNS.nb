  3.603187832150483*^9, 3.603187848734022*^9}}],

Cell["\<\
Create a spatial metric with Coordinate - dependent metric potentials, \
introducing the variable change \[Sigma] = \[Gamma]-\[Rho] with additional \
introduction of functional dependence\
\>", "Text",
 CellChangeTimes->{{3.581937417854555*^9, 3.581937449689299*^9}, {
  3.603180339282419*^9, 3.603180353546156*^9}, {3.6031809352693787`*^9, 
  3.603180947125424*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{"coordvars", "=", 
   RowBox[{"{", 
    RowBox[{"x", ",", "y", ",", "z"}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sTof", ":=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"\[Gamma]", "-", "\[Rho]"}], "\[Rule]", 
      RowBox[{"\[Sigma]", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}]}], ",", 
     RowBox[{"\[Gamma]", "\[Rule]", 
      RowBox[{"\[Gamma]", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}]}], " ", ",", 
     RowBox[{"\[Rho]", "\[Rule]", 
      RowBox[{"\[Rho]", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}]}], ",", " ", 
     RowBox[{"\[Alpha]", "\[Rule]", 
      RowBox[{"\[Alpha]", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}]}], ",", " ", 
     RowBox[{"\[Omega]", "\[Rule]", 
      RowBox[{"\[Omega]", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}]}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"invlapsec", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "/", "lapse"}], ")"}], "/.", "sTof"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Gamma]ijc", "=", 
   RowBox[{"\[Gamma]ij", "/.", "sTof"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"u\[Gamma]ijc", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"Inverse", "[", "\[Gamma]ijc", "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"beta3downc", "=", 
   RowBox[{"beta3down", "/.", "sTof"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.581945823963015*^9, 3.5819458361466427`*^9}, {
   3.5819582498196497`*^9, 3.581958257724566*^9}, {3.603180812637658*^9, 
   3.6031808348225603`*^9}, {3.603181077301345*^9, 3.603181198444675*^9}, {
   3.603181277068838*^9, 3.603181306629622*^9}, {3.604917982318685*^9, 
   3.604918002537767*^9}, 3.6049181616390257`*^9}],

Cell["\<\
Introduce lists to go back to non - function versions of the metric potential \
as well as rules for making the results more readable\
\>", "Text",
 CellChangeTimes->{{3.60318091237755*^9, 3.603180957077423*^9}, {
   3.603182543232539*^9, 3.603182549592497*^9}, 3.603187801743205*^9}],

Cell[BoxData[{
 RowBox[{
  RowBox[{"fTos", ":=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"\[Gamma]", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}], "\[Rule]", "\[Gamma]"}], ",", 
     RowBox[{
      RowBox[{"\[Rho]", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}], "\[Rule]", "\[Rho]"}], ",", 
     RowBox[{
      RowBox[{"\[Alpha]", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}], "\[Rule]", "\[Alpha]"}], ",", 
     RowBox[{
      RowBox[{"\[Sigma]", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}], "\[Rule]", "\[Sigma]"}], ",", 
     RowBox[{
      RowBox[{"\[Omega]", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}], "\[Rule]", "\[Omega]"}], ",", 
     RowBox[{
      RowBox[{"inv\[Alpha]", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}], "\[Rule]", " ", 
      "inv\[Alpha]"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"readablederivs", ":=", 
   RowBox[{"Flatten", "[", " ", 
    RowBox[{"{", "\[IndentingNewLine]", "   ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          SuperscriptBox["\[Alpha]", 
           TagBox[
            RowBox[{"(", 
             RowBox[{"0", ",", "1", ",", "0"}], ")"}],
            Derivative],
           MultilineFunction->None], "[", 
          RowBox[{"x", ",", "y", ",", "z"}], "]"}], "\[Rule]", " ", 
         "d\[Alpha]dy"}], ",", 
        RowBox[{
         RowBox[{
          SuperscriptBox["\[Alpha]", 
           TagBox[
            RowBox[{"(", 
             RowBox[{"1", ",", "0", ",", "0"}], ")"}],
            Derivative],
           MultilineFunction->None], "[", 
          RowBox[{"x", ",", "y", ",", "z"}], "]"}], "\[Rule]", " ", 
         "d\[Alpha]dx"}], ",", 
        RowBox[{
         RowBox[{
          SuperscriptBox["\[Alpha]", 
           TagBox[
            RowBox[{"(", 
             RowBox[{"0", ",", "0", ",", "1"}], ")"}],
            Derivative],
           MultilineFunction->None], "[", 
          RowBox[{"x", ",", "y", ",", "z"}], "]"}], "\[Rule]", " ", 
         "d\[Alpha]dz"}]}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          SuperscriptBox["\[Omega]", 
           TagBox[
