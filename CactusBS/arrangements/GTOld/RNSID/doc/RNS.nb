Cell[CellGroupData[{

Cell["Set quantities for checks, General", "Subsubsection",
 CellChangeTimes->{{3.60412119720992*^9, 3.604121213940304*^9}}],

Cell["\<\
We must remember that the derivatives of the potentials within Kij are also \
dependent on space! Define extra rules to make 2nd derivatives of these \
readable, and use the chain rule.\
\>", "Text",
 CellChangeTimes->{{3.6049186350299673`*^9, 3.6049186660661087`*^9}, {
  3.6049187521901484`*^9, 3.604918785416421*^9}, {3.6049189184550943`*^9, 
  3.604918920927178*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"readablederivs2", ":=", 
   RowBox[{"Flatten", "[", " ", 
    RowBox[{"{", "\[IndentingNewLine]", "   ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          SuperscriptBox["\[Alpha]", 
           TagBox[
            RowBox[{"(", 
             RowBox[{"1", ",", "1", ",", "0"}], ")"}],
            Derivative],
           MultilineFunction->None], "[", 
          RowBox[{"x", ",", "y", ",", "z"}], "]"}], "\[Rule]", " ", 
         "d\[Alpha]dxdy"}], ",", 
        RowBox[{
         RowBox[{
          SuperscriptBox["\[Alpha]", 
           TagBox[
            RowBox[{"(", 
             RowBox[{"1", ",", "0", ",", "0"}], ")"}],
            Derivative],
           MultilineFunction->None], "[", 
          RowBox[{"x", ",", "y", ",", "z"}], "]"}], "\[Rule]", " ", 
         "d\[Alpha]dx"}], ",", 
        RowBox[{
         RowBox[{
          SuperscriptBox["\[Alpha]", 
           TagBox[
            RowBox[{"(", 
             RowBox[{"0", ",", "0", ",", "1"}], ")"}],
            Derivative],
           MultilineFunction->None], "[", 
          RowBox[{"x", ",", "y", ",", "z"}], "]"}], "\[Rule]", " ", 
         "d\[Alpha]dz"}]}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          SuperscriptBox["\[Omega]", 
           TagBox[
            RowBox[{"(", 
             RowBox[{"0", ",", "1", ",", "0"}], ")"}],
            Derivative],
           MultilineFunction->None], "[", 
          RowBox[{"x", ",", "y", ",", "z"}], "]"}], "\[Rule]", " ", 
         "d\[Omega]dy"}], ",", 
        RowBox[{
         RowBox[{
          SuperscriptBox["\[Omega]", 
           TagBox[
            RowBox[{"(", 
             RowBox[{"1", ",", "0", ",", "0"}], ")"}],
            Derivative],
           MultilineFunction->None], "[", 
          RowBox[{"x", ",", "y", ",", "z"}], "]"}], "\[Rule]", " ", 
         "d\[Omega]dx"}], ",", 
        RowBox[{
         RowBox[{
          SuperscriptBox["\[Omega]", 
           TagBox[
            RowBox[{"(", 
             RowBox[{"0", ",", "0", ",", "1"}], ")"}],
            Derivative],
           MultilineFunction->None], "[", 
          RowBox[{"x", ",", "y", ",", "z"}], "]"}], "\[Rule]", " ", 
         "d\[Omega]dz"}]}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          SuperscriptBox["\[Sigma]", 
           TagBox[
            RowBox[{"(", 
             RowBox[{"0", ",", "1", ",", "0"}], ")"}],
            Derivative],
           MultilineFunction->None], "[", 
          RowBox[{"x", ",", "y", ",", "z"}], "]"}], "\[Rule]", " ", 
         "d\[Sigma]dy"}], ",", 
        RowBox[{
         RowBox[{
          SuperscriptBox["\[Sigma]", 
           TagBox[
            RowBox[{"(", 
             RowBox[{"1", ",", "0", ",", "0"}], ")"}],
            Derivative],
           MultilineFunction->None], "[", 
          RowBox[{"x", ",", "y", ",", "z"}], "]"}], "\[Rule]", " ", 
         "d\[Sigma]dx"}], ",", 
        RowBox[{
         RowBox[{
          SuperscriptBox["\[Sigma]", 
           TagBox[
            RowBox[{"(", 
             RowBox[{"0", ",", "0", ",", "1"}], ")"}],
            Derivative],
           MultilineFunction->None], "[", 
