Cell[CellGroupData[{

Cell["Checks for Sanity", "Subsection",
 CellChangeTimes->{{3.604046537238714*^9, 3.604046553223669*^9}, 
   3.6041211839805317`*^9, {3.604135579717795*^9, 3.604135581373275*^9}}],

Cell[TextData[{
 "Checking the momentum constraint, by calculating ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["j", "i"], TraditionalForm]]],
 " assuming ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["M", "i"], "=", "0"}], TraditionalForm]]],
 ".\n",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["K", "ij"], "=", 
   RowBox[{
    FractionBox["1", 
     RowBox[{"2", "\[Alpha]"}]], 
    RowBox[{"(", " ", 
     RowBox[{
      RowBox[{
       SubscriptBox["D", "i"], 
       SubscriptBox["\[Beta]", "j"]}], "+", " ", 
      RowBox[{
       SubscriptBox["D", "j"], 
       SubscriptBox["\[Beta]", "i"]}]}], ")"}]}]}]], "Text",
  CellChangeTimes->{{3.6031878912577763`*^9, 3.6031880644183073`*^9}, {
   3.60318920320183*^9, 3.6031892528656473`*^9}, {3.60318943648827*^9, 
   3.603189508315688*^9}}],
 "\n",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["M", "i"], "=", 
   RowBox[{
    RowBox[{
     SubscriptBox["D", "k"], 
     RowBox[{"(", " ", 
      RowBox[{
       SuperscriptBox["K", "ik"], "-", 
       RowBox[{
        SuperscriptBox["\[Gamma]", "ik"], "K"}]}], ")"}]}], "-", 
    RowBox[{"8", "\[Pi]", " ", 
     SuperscriptBox["j", "i"]}]}]}]], "Text",
  CellChangeTimes->{{3.6031878912577763`*^9, 3.6031880644183073`*^9}, {
   3.60318920320183*^9, 3.6031892528656473`*^9}, {3.60318943648827*^9, 
   3.603189508315688*^9}}],
 "\n",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["j", "i"], "=", 
   RowBox[{
    FractionBox["1", 
     RowBox[{"8", "\[Pi]"}]], 
    SubscriptBox["D", "k"], 
    RowBox[{"(", " ", 
     RowBox[{
      SuperscriptBox["K", "ik"], "-", 
      RowBox[{
       SuperscriptBox["\[Gamma]", "ik"], "K"}]}], ")"}]}]}]], "Text",
  CellChangeTimes->{{3.6031878912577763`*^9, 3.6031880644183073`*^9}, {
   3.60318920320183*^9, 3.6031892528656473`*^9}, {3.60318943648827*^9, 
   3.603189508315688*^9}}],
 "\nAs the momentum is in the \[Phi]-hat direction, so should j^i be. That \
is:\n1. ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["j", "z"], TraditionalForm]]],
 " should vanish analytically\n2. ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["j", "x"], TraditionalForm]]],
 " and ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["j", "y"], TraditionalForm]]],
 " should be related such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["j", "x"], "/", 
     SuperscriptBox["j", "y"]}], "=", 
    RowBox[{
     FractionBox[
      RowBox[{"-", "y"}], "x"], "=", 
     RowBox[{
      RowBox[{"-", "tan"}], " ", "\[Phi]"}]}]}], TraditionalForm]]]
}], "Text",
 CellChangeTimes->{{3.6040464165338993`*^9, 3.6040464249668407`*^9}, {
  3.604046535766555*^9, 3.604046535939102*^9}, {3.604051183009883*^9, 
  3.604051192205531*^9}, {3.60405323679456*^9, 3.6040533062691383`*^9}, {
  3.604054334121291*^9, 3.6040543965036173`*^9}, {3.6040632103277617`*^9, 
  3.604063321429029*^9}, {3.604063398620365*^9, 3.604063406421547*^9}, {
  3.604063517476674*^9, 3.604063532165416*^9}}],

