Cell[CellGroupData[{

Cell["Rotating NS, Isotropic Polar Spherical to Cartesian", "Section",
 CellChangeTimes->{{3.495377994386994*^9, 3.4953780326194468`*^9}, {
  3.581918445396895*^9, 3.581918462704644*^9}, {3.603173260059326*^9, 
  3.603173270474263*^9}, {3.6031738188381987`*^9, 3.603173821158107*^9}, {
  3.603191112716714*^9, 3.6031911140355167`*^9}}],

Cell[TextData[{
 "The metric as solved for by the RNSID code is of the form :\n",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["ds", "2"], "=", 
   RowBox[{
    RowBox[{
     RowBox[{"-", " ", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"\[Gamma]", "+", "\[Rho]"}]]}], 
     SuperscriptBox["dt", "2"]}], " ", "+", " ", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"\[Gamma]", "-", "\[Rho]"}]], 
     SuperscriptBox["r", "2"], 
     SuperscriptBox[
      RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"], 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"d\[Phi]", " ", "-", 
        RowBox[{"\[Omega]", " ", "dt"}]}], ")"}], "2"]}], " ", "+", " ", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"2", "\[Alpha]"}]], 
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["dr", "2"], "+", 
       RowBox[{
        SuperscriptBox["r", "2"], 
        SuperscriptBox["d\[Theta]", "2"]}]}], ")"}]}]}]}]], "Input",
  CellChangeTimes->{{3.5819204070788794`*^9, 3.581920536001099*^9}, {
    3.5819207269923964`*^9, 3.581920744880402*^9}, {3.5819208169274893`*^9, 
    3.5819208604604797`*^9}, 3.5819454748562307`*^9, {3.602335769971574*^9, 
    3.602335787429965*^9}}],
 "\nand then transform the coordinates ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{
     OverscriptBox["r", "_"], ",", 
     OverscriptBox["\[Theta]", "_"], ",", "\[Zeta]"}], ")"}], 
   TraditionalForm]]],
 " such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox["r", "_"], "=", "r"}], ",", " ", 
    RowBox[{
     OverscriptBox["\[Theta]", "_"], "=", "\[Theta]"}], ",", " ", 
    RowBox[{"\[Zeta]", "=", 
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"\[Gamma]", "-", "\[Rho]"}], ")"}], "/", "2"}], "-", 
        "\[Alpha]"}]], 
      RowBox[{"\[Phi]", "."}]}]}]}], TraditionalForm]]],
 "\n",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["ds", "2"], ":=", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"\[Gamma]", "-", "\[Rho]"}]], 
        SuperscriptBox["\[Omega]", 
         RowBox[{"2", " "}]], 
        SuperscriptBox["r", "2"], " ", 
        SuperscriptBox[
         RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}], "-", " ", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"\[Gamma]", "+", "\[Rho]"}]]}], ")"}], 
     SuperscriptBox["dt", "2"]}], " ", "-", 
    RowBox[{"2", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"\[Alpha]", "+", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"\[Gamma]", "-", "\[Rho]"}], ")"}], "/", "2"}]}]], 
     "\[Omega]", " ", 
     SuperscriptBox["r", "2"], 
     SuperscriptBox[
      RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"], "d\[Zeta]", " ", "dt"}], 
    " ", "+", " ", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"2", "\[Alpha]"}]], 
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["dr", "2"], "+", 
       RowBox[{
        SuperscriptBox["r", "2"], 
        SuperscriptBox["d\[Theta]", "2"]}], "+", 
       RowBox[{
        SuperscriptBox["r", "2"], 
        SuperscriptBox[
         RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"], " ", 
        SuperscriptBox["d\[Zeta]", "2"]}]}], ")"}]}]}]}]], "Input",
  CellChangeTimes->{{3.5819204070788794`*^9, 3.581920536001099*^9}, {
    3.5819207269923964`*^9, 3.581920744880402*^9}, {3.5819208169274893`*^9, 
    3.5819208604604797`*^9}, 3.5819454748562307`*^9, {3.602335769971574*^9, 
    3.602335787429965*^9}, {3.603173890254345*^9, 3.603173892550188*^9}, {
    3.603174174652529*^9, 3.603174194359756*^9}, {3.603174282694285*^9, 
    3.603174346971177*^9}, {3.603174385570999*^9, 3.603174387402904*^9}, {
    3.603174575528925*^9, 3.603174615980198*^9}, {3.6031747120340157`*^9, 
    3.603174718536438*^9}}],
 "\n\nConverting to Cartesian base with the components still being governed \
by ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"r", ",", "\[Theta]", ",", "\[Zeta]"}], ")"}], 
   TraditionalForm]]],
 " ...\n   ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["dr", "2"], "=", 
    SuperscriptBox[
     RowBox[{"(", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"Cos", "[", "\[Zeta]", "]"}], 
        RowBox[{"Sin", "[", "\[Theta]", "]"}], "dx"}], " ", "+", " ", 
       RowBox[{
        RowBox[{"Sin", "[", "\[Zeta]", "]"}], 
        RowBox[{"Sin", "[", "\[Theta]", "]"}], "dy"}], "+", 
       RowBox[{
        RowBox[{"Cos", "[", "\[Theta]", "]"}], "dz"}]}], ")"}], "2"]}], 
   TraditionalForm]]],
 "\n   ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["r", "2"], 
     SuperscriptBox["d\[Theta]", "2"]}], "=", 
    RowBox[{"(", " "}]}], TraditionalForm]]],
 "Cos[\[Zeta]] Cos[\[Theta]] dx + Sin[\[Zeta]] Cos[\[Theta]] dy - \
Sin[\[Theta]] dz ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[")", "2"], TraditionalForm]]],
 "\n   ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["r", "2"], 
     SuperscriptBox[
      RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"], 
     SuperscriptBox["d\[Zeta]", "2"]}], "=", 
    SuperscriptBox[
     RowBox[{"(", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"Cos", "[", "\[Zeta]", "]"}], " ", "dy"}], " ", "-", " ", 
       RowBox[{
        RowBox[{"Sin", "[", "\[Zeta]", "]"}], " ", "dx"}]}], " ", ")"}], 
     "2"]}], TraditionalForm]]],
 " \n   ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["r", "2"], 
     SuperscriptBox[
      RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"], "d\[Zeta]"}], "=", 
    RowBox[{
     RowBox[{"x", " ", "dy"}], " ", "-", " ", 
     RowBox[{"y", " ", "dx"}]}]}], TraditionalForm]]],
 " "
}], "Text",
 CellChangeTimes->{{3.5819203883810787`*^9, 3.58192040523973*^9}, 
   3.581920544924983*^9, {3.603179254506934*^9, 3.6031792614276543`*^9}, {
   3.603180087444153*^9, 3.603180090276354*^9}, {3.603181251795293*^9, 
   3.603181263571347*^9}, {3.603191120308495*^9, 3.6031912855308533`*^9}, {
   3.603191321046801*^9, 3.60319138761028*^9}, {3.603191494220196*^9, 
   3.603191542047553*^9}}],

Cell[CellGroupData[{

Cell["Construct the line element and coefficients", "Subsection",
 CellChangeTimes->{{3.604990389130074*^9, 3.604990402955258*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"lineElement", "[", 
     RowBox[{
     "x_", ",", "y_", ",", "z_", ",", "\[Gamma]_", ",", "\[Rho]_", ",", 
      "\[Alpha]_", ",", "\[Omega]_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{"-", 
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{"\[Gamma]", "+", "\[Rho]"}]], "-", 
         RowBox[{
          SuperscriptBox["\[Omega]", "2"], 
          RowBox[{"(", 
           RowBox[{
            SuperscriptBox["x", "2"], "+", 
            SuperscriptBox["y", "2"]}], ")"}], 
          SuperscriptBox["\[ExponentialE]", 
           RowBox[{"\[Gamma]", "-", "\[Rho]"}]]}]}], ")"}]}], 
      SuperscriptBox["dt", "2"]}], "  ", "+", " ", 
     RowBox[{"2", "\[Omega]", " ", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"\[Alpha]", "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"\[Gamma]", "-", "\[Rho]"}], ")"}], "/", "2"}]}]], 
      RowBox[{"(", " ", 
       RowBox[{
        RowBox[{"y", " ", "dx"}], " ", "-", " ", 
        RowBox[{"x", " ", "dy"}]}], " ", ")"}], " ", "dt"}], " ", "+", " ", 
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"2", "\[Alpha]"}]], 
      RowBox[{"(", " ", 
       RowBox[{
        SuperscriptBox["dx", "2"], "+", 
        SuperscriptBox["dy", "2"], "+", 
        SuperscriptBox["dz", "2"]}], ")"}]}]}]}], " ", ";"}], 
  "\[IndentingNewLine]"}]], "Input",
 CellChangeTimes->{{3.581930607613954*^9, 3.581930814430624*^9}, {
  3.581930849271289*^9, 3.581930874566998*^9}, {3.581931373037319*^9, 
  3.581931578615218*^9}, {3.5819334484318933`*^9, 3.58193346314988*^9}, {
  3.581933702023546*^9, 3.581933704090806*^9}, {3.581945480657919*^9, 
  3.581945496515492*^9}, {3.602332106707733*^9, 3.6023321442915277`*^9}, {
  3.602332204903673*^9, 3.602332317898746*^9}, {3.6023357233408546`*^9, 
  3.602335743928293*^9}, {3.603179556369986*^9, 3.603179585985879*^9}, {
  3.6031914359014874`*^9, 3.603191455101715*^9}, {3.6031915857707653`*^9, 
  3.6031915875857897`*^9}}],

Cell["\<\
Verify the line element worked (somehow this isn' t obviously the case?)\
\>", "Text",
 CellChangeTimes->{3.6031796079229918`*^9}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"lineElement", "[", 
  RowBox[{
  "x", ",", "y", ",", "z", ",", "\[Gamma]", ",", "\[Rho]", ",", "\[Alpha]", 
   ",", "\[Omega]"}], "]"}]], "Input",
 CellChangeTimes->{{3.603179611144104*^9, 3.603179620572461*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     SuperscriptBox["dx", "2"], "+", 
     SuperscriptBox["dy", "2"], "+", 
     SuperscriptBox["dz", "2"]}], ")"}], " ", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"2", " ", "\[Alpha]"}]]}], "+", 
  RowBox[{"2", " ", "dt", " ", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"\[Alpha]", "+", 
     FractionBox[
      RowBox[{"\[Gamma]", "-", "\[Rho]"}], "2"]}]], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "dy"}], " ", "x"}], "+", 
     RowBox[{"dx", " ", "y"}]}], ")"}], " ", "\[Omega]"}], "+", 
  RowBox[{
   SuperscriptBox["dt", "2"], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"\[Gamma]", "+", "\[Rho]"}]]}], "+", 
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"\[Gamma]", "-", "\[Rho]"}]], " ", 
