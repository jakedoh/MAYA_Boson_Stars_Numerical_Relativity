Cell[CellGroupData[{

Cell["Rotating NS, Isotropic Polar Spherical", "Section",
 CellChangeTimes->{{3.603173807714387*^9, 3.6031738541206217`*^9}}],

Cell[TextData[{
 "The metric as solved for by the RNSID code is of the form ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["ds", "2"], ":=", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"\[Gamma]", "-", "\[Rho]"}]], 
        SuperscriptBox["\[Omega]", 
         RowBox[{"2", " "}]], 
        SuperscriptBox["r", "2"], " ", 
        SuperscriptBox[
         RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}], "-", " ", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"\[Gamma]", "+", "\[Rho]"}]]}], ")"}], 
     SuperscriptBox["dt", "2"]}], " ", "-", 
    RowBox[{"2", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"\[Alpha]", "+", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"\[Gamma]", "-", "\[Rho]"}], ")"}], "/", "2"}]}]], 
     "\[Omega]", " ", 
     SuperscriptBox["r", "2"], 
     SuperscriptBox[
      RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"], "d\[Zeta]", " ", "dt"}], 
    " ", "+", " ", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"2", "\[Alpha]"}]], 
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["dr", "2"], "+", 
       RowBox[{
        SuperscriptBox["r", "2"], 
        SuperscriptBox["d\[Theta]", "2"]}], "+", 
       RowBox[{
        SuperscriptBox["r", "2"], 
        SuperscriptBox[
         RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"], " ", 
        SuperscriptBox["d\[Zeta]", "2"]}]}], ")"}]}]}]}]], "Input",
  CellChangeTimes->{{3.5819204070788794`*^9, 3.581920536001099*^9}, {
    3.5819207269923964`*^9, 3.581920744880402*^9}, {3.5819208169274893`*^9, 
    3.5819208604604797`*^9}, 3.5819454748562307`*^9, {3.602335769971574*^9, 
    3.602335787429965*^9}, {3.603173890254345*^9, 3.603173892550188*^9}, {
    3.603174174652529*^9, 3.603174194359756*^9}, {3.603174282694285*^9, 
    3.603174346971177*^9}, {3.603174385570999*^9, 3.603174387402904*^9}, {
    3.603174575528925*^9, 3.603174615980198*^9}, {3.6031747120340157`*^9, 
    3.603174718536438*^9}}]
}], "Text",
 CellChangeTimes->{{3.5819203883810787`*^9, 3.58192040523973*^9}, 
   3.581920544924983*^9, {3.6031790809646463`*^9, 3.603179098555695*^9}, {
   3.603179129594371*^9, 3.6031791295945168`*^9}, 3.603191393642139*^9}],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"lineElement", "[", 
    RowBox[{
    "r_", ",", "\[Theta]_", ",", "\[Phi]_", ",", "\[Gamma]_", ",", "\[Rho]_", 
     ",", "\[Alpha]_", ",", "\[Omega]_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"\[Gamma]", "-", "\[Rho]"}]], 
        SuperscriptBox["\[Omega]", 
         RowBox[{"2", " "}]], 
        SuperscriptBox["r", "2"], " ", 
        SuperscriptBox[
         RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}], "-", " ", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"\[Gamma]", "+", "\[Rho]"}]]}], ")"}], 
     SuperscriptBox["dt", "2"]}], " ", "-", 
    RowBox[{"2", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"\[Alpha]", "+", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"\[Gamma]", "-", "\[Rho]"}], ")"}], "/", "2"}]}]], 
     "\[Omega]", " ", 
     SuperscriptBox["r", "2"], 
     SuperscriptBox[
      RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"], "d\[Zeta]", " ", "dt"}], 
    " ", "+", " ", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"2", "\[Alpha]"}]], 
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["dr", "2"], "+", 
       RowBox[{
        SuperscriptBox["r", "2"], 
        SuperscriptBox["d\[Theta]", "2"]}], "+", 
       RowBox[{
        SuperscriptBox["r", "2"], 
        SuperscriptBox[
         RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"], " ", 
        SuperscriptBox["d\[Zeta]", "2"]}]}], ")"}]}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.5819204070788794`*^9, 3.581920536001099*^9}, {
   3.5819207269923964`*^9, 3.581920744880402*^9}, {3.5819208169274893`*^9, 
   3.5819208604604797`*^9}, 3.5819454748562307`*^9, {3.602335769971574*^9, 
