Cell[TextData[{
 "Check whether the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["2", "nd"], TraditionalForm]],
  FormatType->"TraditionalForm"],
 " condition is satisfied:\n   ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"-", 
      SuperscriptBox["\[Beta]", "j"]}], " ", 
     RowBox[{
      SubscriptBox["\[PartialD]", "j"], 
      SuperscriptBox["B", "i"]}]}], " ", "=", 
    RowBox[{
     RowBox[{
      SuperscriptBox["\[Beta]", "j"], 
      RowBox[{
       SubscriptBox["\[PartialD]", "j"], 
       SuperscriptBox[
        OverscriptBox["\[CapitalGamma]", "~"], "i"]}]}], "-", 
     RowBox[{"\[Eta]", " ", 
      SuperscriptBox["B", "i"]}]}]}], TraditionalForm]],
  FormatType->"TraditionalForm"],
 "\n   or\n   ",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    RowBox[{
     RowBox[{"\[Eta]", " ", 
      SuperscriptBox["B", "i"]}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{
        SuperscriptBox["\[Beta]", "j"], 
        RowBox[{
         SubscriptBox["\[PartialD]", "j"], 
         SuperscriptBox["\[CapitalGamma]", "i"]}]}], "+", 
       RowBox[{
        SuperscriptBox["\[Beta]", "j"], " ", 
        RowBox[{
         SubscriptBox["\[PartialD]", "j"], 
         SuperscriptBox["B", "i"]}]}]}], "=", 
      RowBox[{
       SuperscriptBox["\[Beta]", "j"], 
       RowBox[{
        SubscriptBox["\[PartialD]", "j"], 
        RowBox[{"(", 
         RowBox[{
          SuperscriptBox[
           OverscriptBox["\[CapitalGamma]", "~"], "i"], "+", 
          SuperscriptBox["B", "i"]}], ")"}]}]}]}]}]}], TraditionalForm]],
  FormatType->"TraditionalForm"],
 "\n   where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     OverscriptBox["\[CapitalGamma]", "~"], "i"], "=", " ", 
    RowBox[{
     SuperscriptBox[
      OverscriptBox["\[Gamma]", "~"], "jk"], 
     SubscriptBox[
      SuperscriptBox[
       OverscriptBox["\[CapitalGamma]", "~"], "i"], "jk"], " "}]}], 
   TraditionalForm]],
  FormatType->"TraditionalForm"]
}], "Text",
