Cell[CellGroupData[{
Cell["Bondi Infall", "Title",
 CellChangeTimes->{{3.523980761811535*^9, 3.523980770916264*^9}, {
  3.550248583659778*^9, 3.550248585378619*^9}}],

Cell[CellGroupData[{

Cell["Bondi Solution", "Section",
 CellChangeTimes->{{3.536525401217246*^9, 3.53652541656577*^9}, {
   3.538312607015751*^9, 3.538312614783036*^9}, {3.545559402901585*^9, 
   3.545559406026431*^9}, {3.547477405562345*^9, 3.5474774064979467`*^9}, 
   3.550248590923429*^9, {3.550248656270155*^9, 3.550248657469508*^9}}],

Cell[TextData[{
 "Start with HD solution, then add magnetic field.\nSolve the following \
equations:\n     ",
 Cell[BoxData[{
  FormBox[
   RowBox[{
    SubscriptBox["f", "1"], "=", 
    RowBox[{
     RowBox[{
      OverscriptBox["M", "."], "-", 
      RowBox[{"4", 
       SuperscriptBox["\[Pi]\[Rho]ur", "2"]}]}], "=", "0"}]}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    SubscriptBox["f", "2"], "=", 
    RowBox[{
     OverscriptBox["Q", "."], " ", "-", " ", 
     RowBox[{
      SuperscriptBox["h", "2"], "(", 
      RowBox[{"1", "-", 
       FractionBox[
        RowBox[{"2", "M"}], "r"], "+", 
       SuperscriptBox["u", "2"]}], ")"}]}]}], TraditionalForm]}]],
 "\nWhere ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["M", "."], TraditionalForm]]],
 " is the mass flux through any given sphere,\n  and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["Q", "."], "\[Congruent]", 
    SuperscriptBox[
     SubscriptBox["h", "\[Infinity]"], "2"]}], TraditionalForm]]],
 " is a measure of the heat flow.\n  \n  For reference, defaults in \
GRHydro_InitData are\n     ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["M", "."], "=", "12.566370614359172954"}], 
   TraditionalForm]]],
 "\n      ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["r", "S"], "=", "8"}], TraditionalForm]]],
 "\n      ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["r", "min"], "=", 
    SuperscriptBox["10", 
     RowBox[{"-", "15"}]]}], TraditionalForm]]],
 "\n      ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["r", "max"], "=", "400"}], TraditionalForm]]],
 "\n      ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["M", "BH"], "=", "1"}], TraditionalForm]]]
}], "Text",
 CellChangeTimes->{{3.545559413144767*^9, 3.545559435162526*^9}, {
  3.547477410155761*^9, 3.547477469006627*^9}, {3.547477517658606*^9, 
  3.54747759418856*^9}, {3.547477723066682*^9, 3.5474779085914583`*^9}, {
  3.547486073428245*^9, 3.547486162540772*^9}}],

