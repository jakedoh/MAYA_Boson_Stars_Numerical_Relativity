
#############################################################
# Parameter file for running a single puncture with matter
#############################################################

ActiveThorns = "CoordBase SymBase Boundary InitBase CartGrid3d CarpetIOBasic CarpetIOASCII CarpetIOScalar IOUtil Carpet CarpetLib Vectors CarpetReduce CarpetInterp CarpetSlab  LoopControl GSL ADMBase StaticConformal SphericalSurface AEILocalInterp ReflectionSymmetry HydroBase SubspaceNorms CarpetRegrid2 CarpetTracker AHMask SpaceMask GenericFD MoL"

#############################################################
# Grid
#############################################################

CoordBase::domainsize                   = minmax

CoordBase::boundary_size_x_lower        = 3
CoordBase::boundary_size_y_lower        = 3
CoordBase::boundary_size_z_lower        = 3
CoordBase::boundary_shiftout_x_lower    = 1
CoordBase::boundary_shiftout_y_lower    = 1
CoordBase::boundary_shiftout_z_lower    = 1

CoordBase::boundary_size_x_upper        = 3
CoordBase::boundary_size_y_upper        = 3
CoordBase::boundary_size_z_upper        = 3
CoordBase::boundary_shiftout_x_upper    = 0
CoordBase::boundary_shiftout_y_upper    = 0
CoordBase::boundary_shiftout_z_upper    = 0

CartGrid3D::type                        = "coordbase"
CartGrid3D::domain                      = "full"
CartGrid3D::avoid_origin                = "no"

ReflectionSymmetry::reflection_x   = yes
ReflectionSymmetry::reflection_y   = yes
ReflectionSymmetry::reflection_z   = yes
ReflectionSymmetry::avoid_origin_x = no
ReflectionSymmetry::avoid_origin_y = no
ReflectionSymmetry::avoid_origin_z = no

CoordBase::xmin                         = 0
CoordBase::ymin                         = 0
CoordBase::zmin                         = 0
CoordBase::xmax                         = 12
CoordBase::ymax                         = 12
CoordBase::zmax                         = 12
CoordBase::dx                           = 0.5
CoordBase::dy                           = 0.5
CoordBase::dz                           = 0.5

#############################################################
# Mesh refinement
#############################################################

CarpetRegrid2::num_centres          = 1
CarpetRegrid2::regrid_every               = 128
CarpetRegrid2::freeze_unaligned_levels = "yes" 
CarpetRegrid2::freeze_unaligned_parent_levels = "yes" 
CarpetRegrid2::verbose                    = 0
CarpetRegrid2::symmetry_rotating180        = "no"

CarpetRegrid2::num_levels_1  =  1
CarpetRegrid2::position_x_1  =  0
CarpetRegrid2::position_y_1  =  0
CarpetRegrid2::position_z_1  =  0
CarpetRegrid2::radius_1[1]  =  8

#############################################################
# Mesh refinement
#############################################################

Carpet::ghost_size                      = 3
Carpet::domain_from_coordbase           = "yes"
Carpet::max_refinement_levels           = 1
Carpet::refinement_factor               = 2
Carpet::prolongation_order_space        = 5
Carpet::prolongation_order_time         = 2
Carpet::poison_new_timelevels           = "no"
Carpet::check_for_poison                = "no"
Carpet::init_fill_timelevels = "yes"
Carpet::verbose = "yes"
#Carpet::veryverbose = "yes"
#Carpet::enable_all_storage		= "yes"
Carpet::use_buffer_zones		= "yes"

#############################################################
# CarpetLib
#############################################################

CarpetLib::poison_new_memory            = "yes"
CarpetLib::poison_value                 = 114

#############################################################
# Time integration
#############################################################

Cactus::terminate = "iteration"
Cactus::cctk_itlast = 2

#############################################################
# Initial Data
#############################################################
# Minkowski
ADMBase::initial_shift = "zero"

#############################################################
# SphericalSurface
#############################################################

SphericalSurface::nsurfaces  = 6
SphericalSurface::maxntheta  = 120
SphericalSurface::maxnphi    = 40

#############################################################
# Apparent Horizon
#############################################################

#############################################################
# AHMask 
#############################################################

AHMask::use_space_mask = "no"

#############################################################
# Total Mass Thorn
#############################################################
HydroBase::timelevels = 3

SubspaceNorms::debug		= "yes"
SubspaceNorms::norm_as_output   = "yes"
SubspaceNorms::verbose		= "yes"
SubspaceNorms::calc_norms_every  = 2

SubspaceNorms::num_scalars = 1
SubspaceNorms::scalar_variables = "ADMBase::alp" #HydroBase::press"

SubspaceNorms::num_vectors = 1
SubspaceNorms::vector_groups = "ADMBase::shift"

SubspaceNorms::num_tensors = 1
SubspaceNorms::tensor_groups = "ADMBase::metric"


SubspaceNorms::intvolumes	= 4

SubspaceNorms::int_wi_rad[0]	= 50
SubspaceNorms::int_wi_rad[1]	= 3
SubspaceNorms::int_wi_rad[2]	= 5
SubspaceNorms::int_wi_rad[3]	= 8

SubspaceNorms::calc_norms_every_vol[1]  = 1
SubspaceNorms::calc_norms_every_vol[2]  = 0

#############################################################
# Output
#############################################################

IO::out_dir                   = $parfile
IO::out_fileinfo              = "all"
