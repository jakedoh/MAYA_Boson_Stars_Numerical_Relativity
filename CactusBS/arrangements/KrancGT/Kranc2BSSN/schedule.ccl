if (CCTK_EQUALS(update_admbase_variables, "always"))
{
  schedule bssn_evolved_to_adm at CCTK_EVOL as bssn_evolved_to_adm after MoL_Evolution
  {
    LANG: C
    READS: Kranc2BSSN::A11(Everywhere)
    READS: Kranc2BSSN::A21(Everywhere)
    READS: Kranc2BSSN::A31(Everywhere)
    READS: Kranc2BSSN::A22(Everywhere)
    READS: Kranc2BSSN::A32(Everywhere)
    READS: Kranc2BSSN::A33(Everywhere)
    READS: Kranc2BSSN::alpha(Everywhere)
    READS: Kranc2BSSN::beta1(Everywhere)
    READS: Kranc2BSSN::beta2(Everywhere)
    READS: Kranc2BSSN::beta3(Everywhere)
    READS: Kranc2BSSN::h11(Everywhere)
    READS: Kranc2BSSN::h21(Everywhere)
    READS: Kranc2BSSN::h31(Everywhere)
    READS: Kranc2BSSN::h22(Everywhere)
    READS: Kranc2BSSN::h32(Everywhere)
    READS: Kranc2BSSN::h33(Everywhere)
    READS: Kranc2BSSN::K(Everywhere)
    READS: Kranc2BSSN::phi(Everywhere)
    WRITES: admbase::alp(Everywhere)
    WRITES: admbase::betax(Everywhere)
    WRITES: admbase::betay(Everywhere)
    WRITES: admbase::betaz(Everywhere)
    WRITES: admbase::gxx(Everywhere)
    WRITES: admbase::gxy(Everywhere)
    WRITES: admbase::gxz(Everywhere)
    WRITES: admbase::gyy(Everywhere)
    WRITES: admbase::gyz(Everywhere)
    WRITES: admbase::gzz(Everywhere)
    WRITES: admbase::kxx(Everywhere)
    WRITES: admbase::kxy(Everywhere)
    WRITES: admbase::kxz(Everywhere)
    WRITES: admbase::kyy(Everywhere)
    WRITES: admbase::kyz(Everywhere)
    WRITES: admbase::kzz(Everywhere)
  } "bssn_evolved_to_adm"
}

schedule Kranc2BSSN_SelectBoundConds in MoL_PostStep
{
  LANG: C
  OPTIONS: level
  SYNC: h_group
  SYNC: A_group
  SYNC: phi_group
  SYNC: K_group
  SYNC: Gam_group
  SYNC: alpha_group
  SYNC: beta_group
  SYNC: betat_group
} "select boundary conditions"

schedule Kranc2BSSN_CheckBoundaries at BASEGRID
{
  LANG: C
  OPTIONS: meta
} "check boundaries treatment"

schedule Kranc2BSSN_RegisterVars in MoL_Register
{
  LANG: C
  OPTIONS: meta
} "Register Variables for MoL"
schedule group ApplyBCs as Kranc2BSSN_ApplyBCs in MoL_PostStep after Kranc2BSSN_SelectBoundConds
{
} "Apply boundary conditions controlled by thorn Boundary"
