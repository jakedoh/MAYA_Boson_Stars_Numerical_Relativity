      READS: Kranc2BSSN::Gam3(Everywhere)
      READS: Kranc2BSSN::Gam1rhs(Everywhere)
      READS: Kranc2BSSN::Gam2rhs(Everywhere)
      READS: Kranc2BSSN::Gam3rhs(Everywhere)
      WRITES: Kranc2BSSN::beta1rhs(Interior)
      WRITES: Kranc2BSSN::beta2rhs(Interior)
      WRITES: Kranc2BSSN::beta3rhs(Interior)
      WRITES: Kranc2BSSN::betat1rhs(Interior)
      WRITES: Kranc2BSSN::betat2rhs(Interior)
      WRITES: Kranc2BSSN::betat3rhs(Interior)
    } "bssn_external_shift_2ndcentred"
  }
}

