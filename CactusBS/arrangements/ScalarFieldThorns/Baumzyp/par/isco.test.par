#--- distance
dist::dist_verbose = 100
dist::hole_angle = 1.56
dist::dist_ini = 20

#--- nanchecker
NaNChecker::check_every     = 16
NaNChecker::check_vars      = "admbase::metric admbase::curv adm_bssn::ADM_BSSN_sources"
NaNChecker::action_if_found = "terminate"

