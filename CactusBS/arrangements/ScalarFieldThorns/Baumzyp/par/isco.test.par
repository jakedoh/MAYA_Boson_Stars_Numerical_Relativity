#--- generic output directory
IO::out_dir="isco.test"


#--- standard BSSN_MoL evolution
admbase::evolution_method  = "adm_bssn"
mol::ode_method            = "rk3"
admmacros::spatial_order    = 4
adm_bssn::stencil_size      = 2
adm_bssn::advection         = "upwind2"
adm_bssn::bound             = "newrad"
boundary::radpower          = 3
adm_bssn::force_lapse_positive = "yes"


#--- initial maximal solve, then 1+log with dissipation
admbase::initial_lapse          = "one"
admbase::lapse_evolution_method = "coordgauge"
coordgauge::lapse_list          = "1+log"
adm_bssn::lapsesource           = "modified"
adm_bssn::harmonic_f            = 2.0
adm_bssn::LapsePsiPower         = 4
adm_bssn::AlphaDissip           = 2.0

#--- gamma shift with corotation
admbase::initial_shift          = "zero"
admbase::shift_evolution_method = "gamma0"
adm_bssn::ShiftGammaCoeff       = 0.75
adm_bssn::BetaDriver            = 4
adm_bssn::ShiftAlpPower         = 1
adm_bssn::ShiftPsiPower         = 4


#--- horizon finder AEIDevelopment/AHFinderDirect
staticconformal::conformal_timelevels = 3

#ahfinderdirect::verbose_level = "algorithm details"
#ahfinderdirect::N_horizons = 2
#ahfinderdirect::initial_guess__coord_sphere__radius[1]   = 0.25
#ahfinderdirect::initial_guess__coord_sphere__radius[2]   = 4
#ahfinderdirect::origin_x[1]                              = 3
#ahfinderdirect::origin_x[2]                              = 0.0
#ahfinderdirect::initial_guess__coord_sphere__x_center[1] = 3
#ahfinderdirect::initial_guess__coord_sphere__x_center[2] = 0.0
#ahfinderdirect::max_allowable_horizon_radius[2]          = 6

ahfinderdirect::verbose_level = "physics details"
ahfinderdirect::N_horizons = 1
ahfinderdirect::initial_guess__coord_sphere__radius[1]   = 0.25
ahfinderdirect::origin_x[1]                              = 3
ahfinderdirect::initial_guess__coord_sphere__x_center[1] = 3


# sphericalsurface
ahfinderdirect::which_surface_to_store_info[1] = 0
SphericalSurface::symmetric_z[0] = yes
SphericalSurface::nsurfaces = 1
SphericalSurface::maxntheta = 39
SphericalSurface::maxnphi   = 76
sphericalsurface::ntheta      [0] = 22
sphericalsurface::nphi        [0] = 76
sphericalsurface::nghoststheta[0] = 2
sphericalsurface::nghostsphi  [0] = 2

# baum
baum::verbose = 9
baum::max_nsurface = 1
baum::surface_index[0] = 0
baum::eps = 1e-3 # FIXME : better accuracy

#--- noexcision
noexcision::verbose="yes"
noexcision::num_regions=1
noexcision::centre_x[0]=3
noexcision::radius[0]=0.15

#--- http
httpd::port          = 5026
httpd::provide_pages = 1
httpd::use_pthreads  ="yes"

#--- 1D output
IOBasic::outScalar_every = 1
IOASCII::out1D_every     = 1
IOBasic::outInfo_every   = 1
IOBasic::out_format      = "g"
IO::out_zline_x          = 1.168642873
IO::out_yline_x          = 1.168642873


