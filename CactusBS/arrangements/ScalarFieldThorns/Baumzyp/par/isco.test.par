io::strict_io_parameter_check = "no"
staticconformal::conformal_timelevels = 3


#--- preisco initial data
admbase::metric_type         = "static conformal"
admbase::initial_data        = "twopunctures"

twopunctures::par_b = 3.0
twopunctures::par_m_plus = 0.47656
twopunctures::par_m_minus = 0.47656
twopunctures::par_P_plus[1]  = 0.13808
twopunctures::par_P_minus[1] = -0.13808

#twopunctures::verbose = "yes"

twopunctures::Newton_tol = 1e-2 # FIXME : take this out
twopunctures::Newton_maxit = 2 # FIXME : take this out
twopunctures::npoints_A = 9 # FIXME 
twopunctures::npoints_B = 9 # FIXME 
twopunctures::npoints_phi = 10 # FIXME 
#twopunctures::grid_setup_method = "interpolation" # FIXME

# bam params:
#bhm1           = 0.453
#bhy1           = 1.168642873
#bhpx1          = -0.3331917498


# FMR
carpetlib::save_memory_during_regridding = "yes"


# NEW GRID SETUP : NAN AFTER ID
#--- grid
time::dtfac                             = 0.25

grid::type                              = "coordbase"
grid::avoid_origin                     = "no"
grid::domain                            = "bitant"

carpet::domain_from_coordbase = "yes"
