#!/usr/bin/perl -W
# Basic vacuum single black hole spacetime
use List::Util qw(min max);
use POSIX;
use strict;


##############################
## Basic BS Characteristics ##
##############################
  #AH finder and IH spin
  my $ah_every = 4;
  my $ih_every = 32;

  # Default M=1, S=0 BH
  my $mass = 1;
  my $integration_rad = 45;
  my $numpoints = $integration_rad/0.0005 + 1;

  my $central_amp_plus = 0.04;
  my $central_amp_minus = $central_amp_plus;
  my $BS_adm_plus = 5.84390056e-01;
  my $BS_adm_minus =  $BS_adm_plus;
  my $omega_plus = 1.10828046081659304;
  my $omega_minus = $omega_plus;
  my $asymptotic_phi_plus = 3.031192517384311e-08;
  my $asymptotic_phi_minus = $asymptotic_phi_plus;

  my $par_b = 40;
  my $move_origin_x = 0;
  my $rx_plus = ($par_b - $move_origin_x );
  my $rx_minus = (-$par_b - $move_origin_x );

  my @spin = ( (0) x 3 );
  my @momentum = ( (0) x 3 );
  @momentum = map { $_ * $BS_adm_plus } ( 0.3, 0, 0 );


#### Scalar field params

  my $periodic_boundary = "no";
  my $potentialEv = "onlymass";


# Change BH mass (get proper bare mass using Baum)
 #$mass = 0.82;

# Change Spin
 #@spin = ( 0, 0, 0.6 );

  my $Smag = sqrt( $spin[0]**2 + $spin[1]**2 + $spin[2]**2 );

  ## Spectral solve resolution
  my $tp_npts = 60;
          
  ## Physical quantities just used for comments
  my $System_Description;
  $System_Description  = "#########################################################################\n";
  $System_Description .= "# Parameter file for running a single puncture spacetime \n";
  $System_Description .= "#      Mass M_BH = $mass M_h\n";
  $System_Description .= "#      Spin S^i = ($spin[0],$spin[1],$spin[2])\n";
  $System_Description .= "#########################################################################\n";
  print $System_Description;

####################
## Grid Structure ##
####################

my $h = $mass/8;
my $npts = 60; # Points per grid (40, 60, 80), changed as you get coarser
my $rf = $npts*$h;


my $num_rf_levels=7;
my $unistep_last_num_grids = 3;

	# Process above options
        my $ghost_zones = 4;
        my $scaling = 2.;
	my $h0 = sprintf "%.19f", $h * $scaling**($num_rf_levels-1);
	my $fine_dtfac = 0.5;
	my $base_dtfac = $fine_dtfac / $scaling**($unistep_last_num_grids);

	my $joglvls_out_at=$num_rf_levels-1; 
	my $finlvl=$num_rf_levels-1;
	my @rlvls = (0 .. $finlvl);
	my @spacing = (0 .. $finlvl);
	my @spacingdM = (0 .. $finlvl);
	my ($lvl, $Grid_Description);
        my $CarpetRegrid2_radii_1 = "";
        my $CarpetRegrid2_radii_2 = "";
        my $Dissipation_per_level_lines = "";
	$Grid_Description  = "###############################################################################\n##\n";
        $Grid_Description .= "## Grid structure: \n";
   	$Grid_Description .= "##\trl\tExtent\t\tdx[M]\t\tResolution\t\tNpts\n";
   	$Grid_Description .= "##\t===========================================================================\n";
	for ( $lvl=0; $lvl<$num_rf_levels; $lvl++ ){

		$spacing[$lvl] = $h0 / ($scaling**$lvl);
		$spacingdM[$lvl] = 1./$spacing[$lvl];

                ## Grid boundaries increase by factor of 2
	 	my $lvlexponent = $num_rf_levels - $lvl -1;
		$rlvls[$lvl]=$rf*$scaling**$lvlexponent;

                my $npts = $rlvls[$lvl]/$spacing[$lvl];
                my $add_grid_info = sprintf("##\t%-2d\t%-8g\t%-8g\t(M/%-10.6g)\t%-3g^3\n",$lvl,$rlvls[$lvl],$spacing[$lvl],$spacingdM[$lvl],$npts);
		$Grid_Description .= $add_grid_info;
                
		if ($lvl > 0 && $lvl <= $num_rf_levels) {
                   $CarpetRegrid2_radii_1 .= "CarpetRegrid2::radius_1[$lvl] = $rlvls[$lvl]\n";
                   $CarpetRegrid2_radii_2 .= "#CarpetRegrid2::radius_2[$lvl] = $rlvls[$lvl]\n";
		}
                
                ## Choose dissipation
                if ( $spacing[$lvl] > 1. ) {
                   $Dissipation_per_level_lines .= "Dissipation::epsdis_for_level[$lvl] = 0.5\n";
                } else {
                   $Dissipation_per_level_lines .= "Dissipation::epsdis_for_level[$lvl] = 0.1\n";
                }
        
	}
	my $carpet_lvls = $num_rf_levels;

	$Grid_Description  .= "##\n###############################################################################\n";
        print $Grid_Description;

	my $n = int($rf / $h); # (For angular resolution)
	my $m = int($n / 4);   # (For angular resolution and regridding)
	my $ntheta = 16 * $m;
	my $nphi = 2*$ntheta;
	my $merge_margin = 2 * $ghost_zones + 2;

        my $timerefs = "1";
        my @reflvl_timefac = ( (1) x $num_rf_levels );
        my $next=0;
        for ( my $lvl=1; $lvl<$num_rf_levels; $lvl++) {
          if ( $lvl < $unistep_last_num_grids ) {
             $next = 1;
          } else {
             $next = 2**($lvl+1-$unistep_last_num_grids);
          }
          $timerefs = "$timerefs,$next";
          $reflvl_timefac[$lvl] = $next;
        }
	my $every_coarse = $next;
	my @reflvl_freq = ( (1) x $num_rf_levels );
	
	for ( $lvl=0; $lvl<$num_rf_levels; $lvl++)
	{
		$reflvl_freq[$lvl] = $every_coarse/($reflvl_timefac[$lvl]);
	}

	# Process times
	my $dt = $spacing[$num_rf_levels-1]/2.; #dt/it
	my $every_coarse_t = $every_coarse*$dt;
	my $every_10M = sprintf("%.0f", 10./$every_coarse_t)*$every_coarse;
	my $every_1M = sprintf("%.0f", 1./$every_coarse_t)*$every_coarse;
	my $regrid_every = max( ( $m * 16, $every_coarse ) );

my $chiEps = 1e-4;

#################
## Symmetries ##
################
my $reflectx="yes";
my $reflecty="yes";
my $reflectz="yes";
my $rotate180="no";

        # Check symmetries with parameters
        if ( $Smag > 0 && $reflectx eq "yes" ) {
           print "Modifying symmetries: Turning off x-reflection due to spin\n";
           $reflectx = "no";
        }
        if ( $Smag > 0 && $reflecty eq "yes" ) {
           print "Modifying symmetries: Turning off y-reflection due to spin\n";
           $reflecty = "no";
        }
        if ( ( $spin[0] != 0 || $spin[1] != 0 ) && $reflectz eq "yes" ) {
           print "Modifying symmetries: Turning off z-reflection due to spin not parallel to z-axis\n";
           $reflectz = "no";
        }
        if ( ( $spin[0] != 0 || $spin[1] != 0 ) && $rotate180 eq "yes" ) {
           print "Modifying symmetries: Turning off rotation 180 due to spin not parallel to z-axis\n";
           $rotate180 = "no";
        }

        # Process the above options, assuming full and modifying from there
        my $xmin_shiftout = 0;
        my $ymin_shiftout = 0;
        my $zmin_shiftout = 0;
        my $xmin = -$rlvls[0];
        my $ymin = -$rlvls[0];
        my $zmin = -$rlvls[0];
        my $rotatethorn = "";
        my $RS = "#";

        if ($reflectx eq "yes") {
            $xmin_shiftout = 1;
            $xmin = 0;
        }
        if ($reflecty eq "yes") {
            $ymin_shiftout = 1;
            $ymin = 0;
        }
        if ($reflectz eq "yes") {
            $zmin_shiftout = 1;
            $zmin = 0;
        }
        if ($rotate180 eq "yes") {
            $rotatethorn = "RotatingSymmetry180";
            $RS = "";

            # Impose semi-reflectx, un-reflecty
            $reflectx = "no";
            $xmin = 0;
            $xmin_shiftout = 1;

            $reflecty = "no";
            $ymin = -$rlvls[0];
            $ymin_shiftout = 0;
        }

###########
## Times ##
###########
my $final_time = 10000;
my $chkpt_dt = 200;
my $last_it = 1000000;
       my  $cits = int ($chkpt_dt/$dt);

##############
## Analysis ##
##############

my $AH_find_every = 32;  
#$every_10M;

my $num_extraction_spheres = 6;
my $min_extraction_radius = min( ( 30, (0.2*$rlvls[0]/7.) ) );

   my @extraction_sphere_radii = ( );
   my $Multipole_radius_lines = "";
   my $ADM_EJP_radius_lines = "";
   my $scalar_Analysis_radius_lines = "";
   my $Psi4Analysis_radius_lines = "";
   my $dr_extraction = ( 0.95*$rlvls[0] - $min_extraction_radius )/( $num_extraction_spheres + 1. );
   for ( my $sphnum=0; $sphnum<$num_extraction_spheres; $sphnum++ ) {
      my $new_radius = $min_extraction_radius + $sphnum*$dr_extraction; 
      #my $scalar_radius = $min_extraction_radius/20. + $sphnum*$dr_extraction; 
      my $scalar_radius = $min_extraction_radius + $sphnum*$dr_extraction;
      $Multipole_radius_lines .= "Multipole::radius[$sphnum]       = $new_radius\n";
      $ADM_EJP_radius_lines   .= "ADM_EJP::detector_radius [$sphnum] = $new_radius\n";
      $ADM_EJP_radius_lines   .= "ADM_EJP::out_every_det   [$sphnum] = $every_coarse\n";
      $scalar_Analysis_radius_lines   .= "scalarAnalysis::detector_radius [$sphnum] = $scalar_radius\n";
      $scalar_Analysis_radius_lines   .= "scalarAnalysis::out_every_det   [$sphnum] = $every_coarse\n";
      $Psi4Analysis_radius_lines   .= "Psi4Analysis::detector_radius [$sphnum] = $new_radius\n";
      $Psi4Analysis_radius_lines   .= "Psi4Analysis::out_every_det   [$sphnum] = $every_coarse\n";
   }

############
## Output ##
############
#my $out1d = 8 * 2**3; # 8 = Out every on *that* ref lvl
my $out1d = 32;
#my $out2d = 8 * 2**4; # 8 * 2**3
my $out2d = 128;
my $out3d = 0; # 8 * 2**3

        my $chkpt_basenm = "$0";
        $chkpt_basenm =~ s/\.rpar//g;
        $chkpt_basenm =~ s/\.\///g;
        my $chkptdir=$chkpt_basenm."_Chkpt";

my $lines = <<EOF;
$System_Description
$Grid_Description

ActiveThorns = "IHSpin Kranc2BSSNChiMatter_flrw TwoPuncturesSolver_BS BowenID_BS GenericFD CoordBase SymBase Boundary InitBase NanChecker CartGrid3d Time MoL CarpetIOBasic CarpetIOScalar IOUtil Carpet CarpetLib Vectors CarpetReduce CarpetInterp CarpetSlab  CarpetIOASCII LoopControl GSL CarpetRegrid2 CarpetTracker ADMBase StaticConformal Dissipation SphericalSurface AEILocalInterp SpaceMask ReflectionSymmetry $rotatethorn Slab CarpetIOHDF5 SphereIntegrate  AHFinderDirect SphereRad ShiftTracker WeylScal4 Multipole ADM_EJP"
ActiveThorns = "EvolveScalarFields_flrw AHMask ExternalEtaBeta tmunubase ADMCoupling scalarAnalysis"
ActiveThorns = "MinSearch MPI Timers HDF5 CycleClock hwloc zlib ADMMacros PeriodicCarpet Psi4Analysis"

#############################################################
# Grid
#############################################################
PeriodicCarpet::periodic = "$periodic_boundary"

CoordBase::domainsize                   = minmax

CoordBase::boundary_size_x_lower        = $ghost_zones
CoordBase::boundary_size_y_lower        = $ghost_zones
CoordBase::boundary_size_z_lower        = $ghost_zones
CoordBase::boundary_shiftout_x_lower    = $xmin_shiftout
CoordBase::boundary_shiftout_y_lower    = $ymin_shiftout
CoordBase::boundary_shiftout_z_lower    = $zmin_shiftout

CoordBase::boundary_size_x_upper        = $ghost_zones
CoordBase::boundary_size_y_upper        = $ghost_zones
CoordBase::boundary_size_z_upper        = $ghost_zones
CoordBase::boundary_shiftout_x_upper    = 0
CoordBase::boundary_shiftout_y_upper    = 0
CoordBase::boundary_shiftout_z_upper    = 0

CoordBase::xmin                         = $xmin
CoordBase::ymin                         = $ymin
CoordBase::zmin                         = $zmin
CoordBase::xmax                         = $rlvls[0]
CoordBase::ymax                         = $rlvls[0]
CoordBase::zmax                         = $rlvls[0]
CoordBase::dx                           = $h0
CoordBase::dy                           = $h0
CoordBase::dz                           = $h0

CartGrid3D::type                        = "coordbase"
CartGrid3D::domain                      = "full"
CartGrid3D::avoid_origin                = "no"

ReflectionSymmetry::reflection_x   = $reflectx
ReflectionSymmetry::reflection_y   = $reflecty
ReflectionSymmetry::reflection_z   = $reflectz
ReflectionSymmetry::avoid_origin_x = no
ReflectionSymmetry::avoid_origin_y = no
ReflectionSymmetry::avoid_origin_z = no
$RS RotatingSymmetry180::poison_boundaries  = "yes"

#TimerReport::out_every = 128
#RunStats::calc_every = 128


#############################################################
# MinSearch
#############################################################

MinSearch::x0[0]               = $rx_plus
MinSearch::y0[0]               = 0.0
MinSearch::z0[0]               = 0.0
MinSearch::surface_index[0]    = 0
#MinSearch::extra_variables[0] = "HydroBase::eps"
#MinSearch::weight_variable[0] = "AHMask::AHmasked_weight"

MinSearch::nminima             = 1 #2 in the case of unequal mass
MinSearch::dist_cutoff         = 1.47
MinSearch::var                 = "kranc2bssnchimatter::chi"
MinSearch::verbose             = 0
MinSearch::track_maximum       = "no"
MinSearch::find_global_minimum = "no"
MinSearch::find_localized_minimum = "yes"
MinSearch::interpolator_name   = "Lagrange polynomial interpolation"
MinSearch::interpolator_pars   = "order=4"
MinSearch::find_every          = 16
MinSearch::outfile_basename    = "MinSearch%d.asc"

#Uncomment in case of unequal mass
#MinSearch::x0[1]               = $rx_minus
#MinSearch::y0[1]               = 0.0
#MinSearch::z0[1]               = 0.0
#MinSearch::surface_index[1]    = 1

#############################################################
# Mesh refinement
#############################################################

CarpetRegrid2::num_centres          = 1 #2 in the case of unequal mass
CarpetRegrid2::regrid_every               = 16
CarpetRegrid2::freeze_unaligned_levels = "no" 
CarpetRegrid2::freeze_unaligned_parent_levels = "no" 
Carpet::grid_coordinates_filename = "grid.asc" 
CarpetRegrid2::min_distance = 0
CarpetRegrid2::min_fraction = 0.4
CarpetRegrid2::verbose                    = "yes"
CarpetRegrid2::symmetry_rotating180        = "$rotate180"

CarpetTracker::surface     [0] = 0
CarpetRegrid2::num_levels_1  =  $carpet_lvls
CarpetRegrid2::position_x_1  =  $rx_plus
CarpetRegrid2::position_y_1  =  0
CarpetRegrid2::position_z_1  =  0

# 320, 160, 95, 70, 50, 6.875 (dx_max = 10)
# For 1 processor, (6.875, 0.3125 for CoordBase) 
$CarpetRegrid2_radii_1

#Uncomment in the case of unequal mass
#CarpetTracker::surface     [1] = 1
#CarpetRegrid2::num_levels_2  =  $carpet_lvls
#CarpetRegrid2::position_x_2  =  $rx_minus
#CarpetRegrid2::position_y_2  =  0
#CarpetRegrid2::position_z_2  =  0

# 320, 160, 95, 70, 50, 6.875 (dx_max = 10)
# # For 1 processor, (6.875, 0.3125 for CoordBase) 
$CarpetRegrid2_radii_2

#############################################################
# Carpet
#############################################################

Carpet::ghost_size                      = $ghost_zones
Carpet::domain_from_coordbase           = "yes"
Carpet::max_refinement_levels           = $carpet_lvls
Carpet::refinement_factor               = 2
Carpet::prolongation_order_space        = 5
Carpet::prolongation_order_time         = 2
Carpet::use_buffer_zones                = "yes"
Carpet::verbose                         = "no"
Carpet::time_refinement_factors         = "[$timerefs]"
Carpet::output_timers_every             = $every_coarse
Carpet::poison_new_timelevels           = "yes"
Carpet::check_for_poison                = "no"
Carpet::poison_value                    = 113
Carpet::print_timestats_every           = 0
Carpet::init_fill_timelevels            = "yes"
Carpet::use_tapered_grids               = "no"

#############################################################
# CarpetLib
#############################################################

CarpetLib::print_memstats_every         = 0
CarpetLib::poison_new_memory            = "yes"
CarpetLib::poison_value                 = 114

#############################################################
# Time integration
#############################################################

Cactus::terminate = "any"
Cactus::max_runtime = 2850
Cactus::cctk_final_time = $final_time
Cactus::cctk_itlast = $last_it

# Use 0.5 for RK4 and 0.25 for ICN
Time::dtfac                           = $base_dtfac
MethodOfLines::ode_method             = "RK4"
MethodOfLines::MoL_NaN_Check          = "no"
MethodOfLines::MoL_Intermediate_Steps = 4
MethodOfLines::MoL_Num_Scratch_Levels = 1

#############################################################
# Initial data
#############################################################

ADMBase::initial_data = "twopuncturessolver"
ADMBase::initial_lapse = "psi^6"
ADMBase::initial_shift = "zero"
ADMBase::initial_dtshift = "zero"
ADMBase::metric_timelevels = 3
ADMBase::lapse_timelevels = 3
ADMBase::shift_timelevels = 3


ADMBase::evolution_method = "Kranc2BSSNChiMatter"
ADMBase::lapse_evolution_method = "Kranc2BSSNChiMatter"
ADMBase::shift_evolution_method = "Kranc2BSSNChiMatter"
ADMBase::dtlapse_evolution_method = "Kranc2BSSNChiMatter"
ADMBase::dtshift_evolution_method = "Kranc2BSSNChiMatter"

BowenID_BS::verbose = 2
BowenID_BS::testsuite = "yes"
BowenID_BS::rhohat_exponent = 0              #exponent for conformal rescaling of energy density***
BowenID_BS::zero_epsilon = 1e-06             #minimum distance of grid point from puncture***

BowenID_BS::compact_object[0] = "boson star"
BowenID_BS::compact_object[1] = "boson star"

BowenID_BS::BS_central_amplitude[0] = $central_amp_plus
BowenID_BS::omega[0] = $omega_plus
BowenID_BS::BS_asymptotic_amplitude[0] = $asymptotic_phi_plus

BowenID_BS::BS_central_amplitude[1] = $central_amp_minus
BowenID_BS::omega[1] = $omega_minus
BowenID_BS::BS_asymptotic_amplitude[1] = $asymptotic_phi_minus

BowenID_BS::object_rx[0] = $rx_plus
BowenID_BS::object_rx[1] = $rx_minus       

BowenID_BS::object_Px[0] = -$momentum[0]
BowenID_BS::object_Py[0] = $momentum[1]
BowenID_BS::object_Pz[0] = $momentum[2]
BowenID_BS::object_Px[1] = $momentum[0]
BowenID_BS::object_Py[1] = $momentum[1]
BowenID_BS::object_Pz[1] = $momentum[2]

BowenID_BS::tov_numpoints = $numpoints

TwoPuncturesSolver_BS::par_b          =  $par_b
#TwoPuncturesSolver_BS::par_S_plus[0]  =  $spin[0]
#TwoPuncturesSolver_BS::par_S_plus[1]  =  $spin[1]
#TwoPuncturesSolver_BS::par_S_plus[2]  =  $spin[2]
TwoPuncturesSolver_BS::move_origin_x  = $move_origin_x
TwoPuncturesSolver_BS::conformal_density_power = 0 
#TwoPuncturesSolver_BS::epsilon = 1e-3
TwoPuncturesSolver_BS::use_full_transform = "yes"
TwoPuncturesSolver::grid_setup_method = "evaluation"
TwoPuncturesSolver::Newton_maxit   = 40
TwoPuncturesSolver_BS::npoints_A = $tp_npts
TwoPuncturesSolver_BS::npoints_B = $tp_npts

TwopuncturesSolver_BS::scalarPhia = "EvolveScalarFields::phia"
TwopuncturesSolver_BS::scalarPia = "EvolveScalarFields::pia"
TwopuncturesSolver_BS::scalarPhib = "EvolveScalarFields::phib"
TwopuncturesSolver_BS::scalarPib = "EvolveScalarFields::pib"

SpaceMask::use_mask       = "yes"

TwoPuncturesSolver_BS::keep_u_around = "yes"
TwoPuncturesSolver_BS::Newton_tol = 1e-12

#############################################################
# Initial data of matter ( scalar field  )
# Gaussian
#############################################################

EvolveScalarFields::potential_type    = "$potentialEv"  # "inflation" #
EvolveScalarFields::controlmasspositiveornegative = 1
EvolveScalarFields::phiamass = $mass

#############################################################
# a second Scalar field:
#############################################################

EvolveScalarFields::phibmass = $mass

#############################################################
# Spacetime Evolution
#############################################################

# The number of points needed in each direction to calculate using
# derivatives.  
GenericFD::stencil_width 	= 3


kranc2bssnchimatter::m                        = 1
kranc2bssnchimatter::lapseAdvection           = 1
kranc2bssnchimatter::gammaDriverLambda        = 0
kranc2bssnchimatter::betaDotAlphaFactor       = 0.75
kranc2bssnchimatter::etaBeta                  = 1.0
kranc2bssnchimatter::chiBeta                  = 1
kranc2bssnchimatter::gammaDriverLapsePower    = 0
kranc2bssnchimatter::nasaAdvection            = 1
kranc2bssnchimatter::newNASAAdvection         = 1
kranc2bssnchimatter::betatAdvection           = 1
kranc2bssnchimatter::chiEps                   = $chiEps
kranc2bssnchimatter::verbose                  = 0
kranc2bssnchimatter::fd_order                 = "6th"
kranc2bssnchimatter::lapse_condition          = "1 + log 6th"
kranc2bssnchimatter::shift_condition          = "NASA6th"
kranc2bssnchimatter::boundary_condition       = "radiative"
kranc2bssnchimatter::recalculate_constraints  = "matter"
kranc2bssnchimatter::flrwcf  = -1.0
Kranc2BSSNChiMatter::couple_matter = "yes"
kranc2bssnchimatter::harmonicf  = 2.0
kranc2bssnchimatter::betaXasymp = 0 #0.2346853799367281

TmunuBase::timelevels           = 3
TmunuBase::stress_energy_storage    = "yes"
TmunuBase::stress_energy_at_RHS     = "yes" #order_time


EvolveScalarFields::phiaBG               = 0
EvolveScalarFields::fd_order            = "6th" # "full4th" #
EvolveScalarFields::boundary_condition  = "radiative" # "none" #
#EvolveScalarFields::calculate_rho       = "yes"
EvolveScalarFields::phia_group_bound   = "none"
EvolveScalarFields::pia_group_bound    = "none"
EvolveScalarFields::phib_group_bound   = "none"
EvolveScalarFields::pib_group_bound    = "none"

# This lowers the order of accuracy, but some dissipation might be required
Dissipation::order                 = 5
Dissipation::epsdis                = 0.0
$Dissipation_per_level_lines

Dissipation::vars = "Kranc2BSSNChiMatter::A_group Kranc2BSSNChiMatter::alpha_group Kranc2BSSNChiMatter::beta_group Kranc2BSSNChiMatter::betat_group Kranc2BSSNChiMatter::Gam_group Kranc2BSSNChiMatter::h_group Kranc2BSSNChiMatter::K_group Kranc2BSSNChiMatter::chi_group EvolveScalarFields::phia_group EvolveScalarFields::pia_group EvolveScalarFields::phib_group EvolveScalarFields::pib_group"


#############################################################
# Boundary conditions
#############################################################

# These specify that no standard CACTUS boundary condition is to be
# applied. These parameters must be present or the Cactus symmetry
# boundary condition will not be applied. The outgoing radiative
# boundary condition provided by Kranc2BSSN is always applied.
Kranc2BSSNChiMatter::A_group_bound   = "none"
Kranc2BSSNChiMatter::alpha_group_bound = "none"
Kranc2BSSNChiMatter::beta_group_bound = "none"
Kranc2BSSNChiMatter::betat_group_bound = "none"
Kranc2BSSNChiMatter::Gam_group_bound = "none"
Kranc2BSSNChiMatter::h_group_bound = "none"
Kranc2BSSNChiMatter::K_group_bound = "none"
Kranc2BSSNChiMatter::chi_group_bound = "none"

