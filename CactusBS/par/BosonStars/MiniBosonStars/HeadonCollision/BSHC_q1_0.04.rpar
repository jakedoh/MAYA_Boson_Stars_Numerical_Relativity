#############################################################

IHSpin::compute_every          = $ih_every
IHSpin::num_horizons           = 1
IHSpin::surface_index[0]       = 0
IHSpin::compute_every_individual[0] = $ih_every
IHSpin::find_after_individual_time[0] = 600
IHSpin::interpolator_name      = "Lagrange polynomial interpolation"
IHSpin::interpolator_pars      = "order=4"
IHSpin::verbose = 0

#############################################################
